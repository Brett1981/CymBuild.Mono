@page "/QuoteSectionDetail/{RecordGuid}/{SerializedDataObjectReference}/{ReturnUrl}"
@using Google.Protobuf.WellKnownTypes
@using Newtonsoft.Json
@using Concursus.API.Client.Models
@using System.Web
@using Concursus.PWA.Classes
@inherits EditPageBase
@inject Core.CoreClient coreClient
@inject UserService userService
@inject NavigationManager NavManager
@inject RefreshService refreshService
@inject Sage200Microservice.API.Protos.Invoice.InvoiceService.InvoiceServiceClient sageIntegrationService

@attribute [Authorize]

<EditPage @ref="@editPage"
          EntityTypeGuid="d9c04600-46cc-4bc9-acc1-18a850c9e18a"
          Windowed="@Windowed"
          @bind-RecordGuid="@RecordGuid"
          ModalId="@ModalId"
          @bind-ParentDataObjectReference="@ParentDataObjectReference"
          ReturnUrl="@ReturnUrl"
          CloseWindow="@CloseWindow"
          GridUpdated="@GridUpdated"
          IsDetailWindowed="@IsDetailWindowed"
          TransientVirtualProperties="@TransientVirtualProperties">
    <FormTitle>
        <i class="bi bi-briefcase-fill me-2" style="font-size: 1.2rem;"></i>
    </FormTitle>
    <FormBody>

        <FlexPropertyGroups @ref="@editPage.flexPropertyGroups"
                            entityProperties="@editPage.entityProperties"
                            entityPropertyGroups="@editPage.entityPropertyGroups"
                            IsMainRecordContext="@IsMainRecordContext"
                            @bind-dataObject="@editPage.dataObject"
                            RecordGuid="@RecordGuid"
                            inputUpdated="@editPage.HandleInputUpdated"/>

        <DynamicGrid @ref="QuoteItems" GridCode="QUOTEITEMS" OnActionCompleted=RefreshJobProgress ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />

    </FormBody>
</EditPage>

@code {
    [Parameter]
    public string? SerializedDataObjectReference { get; set; }
    [Parameter] public string? ModalId { get; set; }
    [Parameter]
    public EventCallback<DataObjectReference> ParentDataObjectReferenceChanged { get; set; }
    [Parameter]
    public EventCallback<Exception> OnError { get; set; }
    [Parameter] public bool IsDetailWindowed { get; set; } = false;
    [Parameter] public bool IsMainRecordContext { get; set; } = true;
    private API.Client.FormHelper? _formHelper;
    [Parameter]
    public Dictionary<string, Any> TransientVirtualProperties { get; set; } = new();

    public DynamicGrid QuoteItems { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            if (ParentDataObjectReference != null)
            {
                ParentDataObjectReference = JsonConvert.DeserializeObject<DataObjectReference>(HttpUtility.UrlDecode(SerializedDataObjectReference) ?? string.Empty);
                await ParentDataObjectReferenceChanged.InvokeAsync(ParentDataObjectReference);
            }
            await base.OnParametersSetAsync();
        }
        catch (Exception ex)
        {
            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Error);
            ex.Data.Add("Message", "An error occurred while setting parameters on Quote Section Detail");
            ex.Data.Add("PageMethod", "QuoteSectionDetail/OnParametersSetAsync()");
            _ = OnError.InvokeAsync(ex);
        }

    }
    private void RefreshJobProgress()
    {
        if(!IsDetailWindowed)
            _ = LoadData();
    }
    private async Task LoadData()
    {
        try
        {

            if (ParentDataObjectReference != null && ParentDataObjectReference.DataObjectGuid != Guid.Empty)
            {
                _formHelper = new API.Client.FormHelper(coreClient, sageIntegrationService, PWAFunctions.ParseAndReturnEmptyGuidIfInvalid(EntityTypeGuid).ToString(), userService);

                await _formHelper.LoadMetaDataAsync(IsInformationPage);

                var newDataObject = await _formHelper.ReadDataObjectAsync(editPage.RecordGuid, ParentDataObjectReference, false, ParentDataObjectReference.EntityTypeGuid.ToString());
                await ParentDataObjectReferenceChanged.InvokeAsync(ParentDataObjectReference);
                if (!string.IsNullOrEmpty(newDataObject.ErrorReturned))
                {
                    throw new Exception(newDataObject.ErrorReturned);
                }
                if (newDataObject.ProgressData != null)
                {
                    editPage.dataObject = newDataObject;
                    editPage.MyDataObjectReference = ParentDataObjectReference;
                }



                NavManager.NavigateTo(NavManager.Uri, forceLoad: false);
                StateHasChanged();
                QuoteItems?.Dgv?.RefreshMe();

            }
        }
        catch (Exception ex)
        {
            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Error);
            ex.Data.Add("Message", "An error occurred while loading data on Quote Section Detail");
            ex.Data.Add("PageMethod", "QuoteSectionDetail/LoadData()");
            _ = OnError.InvokeAsync(ex);
        }
    }

}