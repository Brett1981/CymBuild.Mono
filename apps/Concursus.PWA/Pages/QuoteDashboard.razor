@page "/quote-dashboard"
@using System.Globalization
@using System.Text
@inject IJSRuntime JsRuntime
@inject Core.CoreClient coreClient
@using System.Text.Json;
@using Concursus.API.Client.Models;
@using System.Web;
@inject NavigationManager NavManager
@using Newtonsoft.Json;


@* NOTE: If importing the control to the Dashboard as a widget we need to set the following like so for inheritance:
    <QuoteDashboard class="quote-dashboard-widget" />

    Or

    <div style="height: 100%; width: 100%; display: flex; flex-direction: column;">
        <QuoteDashboard style="flex-grow: 1;" />
    </div>


*@

<div class="dashboard-wrapper">
    <div class="dashboard-container">
        <h2>Dashboard</h2>

    @*     <div class="export-bar">
            <TelerikButton OnClick="@ExportToCsv">Export to CSV</TelerikButton>
            <TelerikButton OnClick="@ExportToPdf">Export to PDF</TelerikButton>
        </div> *@
        <div class="filter-bar">
            <label>Time frame:</label>
            <select @bind="Grouping">
                @foreach (TimeGrouping g in Enum.GetValues(typeof(TimeGrouping)))
                {
                    <option value="@g">@g.ToString()</option>
                }
            </select>
        </div>
        <div class="filter-bar">
            <label>Date Range:</label>
            <input type="date" value="@StartDate.ToString("yyyy-MM-dd")" @onchange="OnStartDateChanged" />
            <input type="date" value="@EndDate.ToString("yyyy-MM-dd")" @onchange="OnEndDateChanged" />
        </div>

        <div class="filter-bar">
            <label>Filter by Value:</label>
            <input type="range" min="0" max="100000" step="1000" value="@ValueFilter" @oninput="OnValueFilterChanged" />
            <span>@ValueFilter.ToString("C", CultureInfo.CreateSpecificCulture("en-GB"))</span>
        </div>

        <div class="kpi-summary">
            <div class="kpi-card">
                <div class="kpi-title">Total Value</div>
                <div class="kpi-value">@TotalQuoteValue.ToString("C", CultureInfo.CreateSpecificCulture("en-GB"))</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-title">Average Quote Value</div>
                <div class="kpi-value">@AverageQuoteValue.ToString("C", CultureInfo.CreateSpecificCulture("en-GB"))</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-title">Quotes Above £50K</div>
                <div class="kpi-value">@QuotesAboveFiftyKCount (@PercentageAboveFiftyK%)</div>
            </div>
        </div>

        <div class="kpi-summary2">
            <div>
                <label>Job Type:</label>
                <TelerikMultiSelect Data="@JobTypes"
                                    Value="@SelectedJobType"
                                    ValueChanged="@( async (List<string> vals) => await SetChartData(vals))"
                                    Placeholder="Select job types..."
                                    AutoClose="false" />

                <label>Status:</label>
                <TelerikMultiSelect Data="@JobStatuses"
                                    Value="@SelectedJobStatus"
                                    ValueChanged="@((List<string> vals) => {
                                                                    SelectedJobStatus = vals;
                                                                    RebindChart();
                                                                })"
                                    Placeholder="Select job statuses..."
                                    AutoClose="false" />
            </div>

        </div>

        <div class="chart-container" >
            <TelerikChart
                Width="100%"
                Height="100%"
                OnSeriesClick="@OnChartClick"
                @key="FilteredChartData.Count">


                 <!--[SHOW "NO DATA" MESSAGE]-->
                <ChartSettings>
                    <NoDataTemplate>
                        <p>No data available to display. Please select a type from the status dropdown.</p>
                    </NoDataTemplate>
                </ChartSettings>

                <!--[ENABLE PANNING]-->
                <ChartPannable Enabled="true"/>
                  <!--[CHART LEGEND ORIENTATION]-->
                <ChartLegend Position="ChartLegendPosition.Bottom"/>



                <ChartSeriesItems>
                    @foreach (var statusGroup in FilteredChartData.GroupBy(q => q.Status))
                    {
                        foreach (var quoteTypeGroup in statusGroup.GroupBy(q => q.QuoteType))
                        {
                            //E.g. "New - CDM"
                            var combinedLabel = $"{statusGroup.Key} - {quoteTypeGroup.Key}";

                            <ChartSeries Type="ChartSeriesType.Column"
                                         Name="@combinedLabel"
                                         Data="@quoteTypeGroup.ToList()"
                                         Field="Value"
                                         Gap="0.2"
                                         Spacing="0.2"
                                         CategoryField="Label"
                                         Color="@GetColorForStatus(statusGroup.Key)">
                                <ChartSeriesStack Group="@quoteTypeGroup.Key" />
                                <ChartSeriesTooltip Visible="true">
                                   <Template>

                                        @{
                                            var tooltipContext = context as Telerik.Blazor.Components.ChartSeriesTooltipTemplateContext;
                                            var data = tooltipContext?.DataItem as FilteredQuoteChartData;

                                            var baseURL = NavManager.BaseUri + "QuoteDetail/";
                                            var returnUrl = HttpUtility.UrlEncode(NavManager.Uri);
                                        }

                                        <div style="padding: 4px;">
                                            <strong>@data?.Label</strong><br />
                                            Status: @data?.Status<br />
                                            Type: @data?.QuoteType<br />
                                          
                                            Amount: £@data?.QuoteValue <br />
                                            Date: @data?.Date.ToString("dd MMM yyyy") <br />
                                            Records:
                                            @if (data?.Quotes != null)
                                            {
                                                foreach (var q in data.Quotes)
                                                {
                                                     var dataobjectReference = new DataObjectReference(q.Guid, "1c4794c1-f956-4c32-b886-5500ac778a56");
                                                     var serializedDataObjectReferemce =  HttpUtility.UrlEncode(JsonConvert.SerializeObject(dataobjectReference));
                                                     var url = baseURL + q.Guid + "/" + serializedDataObjectReferemce + "/" + returnUrl;

                                                    <a href="@url" target="_blank" style="font-weight:bold; color:white; text-decoration:none;">
                                                        <u> @q.QuoteNumber </u>
                                                    </a>@(q != data.Quotes.Last() ? ", " : "") //Logic for comma seperation.
                                                }
                                            }
                                        </div>
                                    </Template>
                                </ChartSeriesTooltip>
                            </ChartSeries>


                            <!--X-->
                            <ChartCategoryAxes>
                                <ChartCategoryAxis BaseUnitStep="1"  Categories="@ValueRangeLabels.ToArray()" />
                            </ChartCategoryAxes>

                            <!--Y-->
                            <ChartValueAxes>
                               <ChartValueAxis MajorUnit="1" MinorUnit="1"  />
                            </ChartValueAxes>

                            <!--[SHOW THE LEGEND AT THE BOTTOM]-->
                            <ChartLegend Position="Telerik.Blazor.ChartLegendPosition.Bottom"/>
                        }
                    }
                </ChartSeriesItems>
        </TelerikChart>
        </div>
    </div>
</div>

@code {

    //List of quote records.
    private List<QuoteChartData> ChartData { get; set; } = new();
    private List<FilteredQuoteChartData> RangedData { get; set; } = new();
    private List<FilteredQuoteChartData> FilteredChartData = new();

    //Different labels.
    private List<string> Clients => ChartData.Select(c => c.Client).Distinct().ToList();
    private List<string> QuoteTypes => new() { "CDM PD", "CDM PCI", "BRAC WORK" };
    private List<string> ValueRangeLabels => FilteredChartData.Select(d => d.Label).Distinct().ToList();



    private int ValueFilter = 50000;
    private Dictionary<string, string> QuoteTypeColors = new();
    private Dictionary<string, string> QuoteStatusColors = new();
    private Random rand = new();
    private Timer filterDebounceTimer;

    private decimal TotalQuoteValue = 0;
    private decimal AverageQuoteValue = 0;
    private int QuotesAboveFiftyKCount = 0;
    private int PercentageAboveFiftyK = 0;

    private int QuotesSent = 0;
    private int QuotesAccepted = 0;
    private int QuotesRejected = 0;



    private decimal DateRangeTotal = 0;
    private decimal DateRangeAverage = 0;
    private int DateRangeAboveFiftyK = 0;

    public enum TimeGrouping { Daily, Weekly, Monthly }

    private TimeGrouping Grouping
    {
        get => grouping;
        set
        {
            grouping = value;
            RebindChart();
        }
    }
    private TimeGrouping grouping = TimeGrouping.Weekly;
    private DateTime startDate = DateTime.Today.AddDays(-30);
    private DateTime StartDate
    {
        get => startDate;
        set
        {
            startDate = value;
            RebindChart();

        }
    }

    private DateTime endDate = DateTime.Today;
    private DateTime EndDate
    {
        get => endDate;
        set
        {
            endDate = value;
            RebindChart();
        }
    }


    Dictionary<string, int> NumberOfRecordsPerType { get; set; } = new Dictionary<string, int>();

    public class QuoteChartData
    {
        public int QuoteID { get; set; }
        public string QuoteNumber { get; set; }
        public string Guid { get; set; }
        public string Label { get; set; }
        public int Value { get; set; }
        public int Min { get; set; }
        public int Max { get; set; }
        public DateTime Date { get; set; }
        public string Status { get; set; }
        public string Client { get; set; }
        public string QuoteType { get; set; }
        public double QuoteValue { get; set; }
    }

    public record QuoteInfo(string QuoteNumber, string Guid);

    public class FilteredQuoteChartData
    {
        public int QuoteID { get; set; }
        public List<QuoteInfo> Quotes { get; set; } = new();

        public string Label { get; set; }
        public int Value { get; set; }
        public int Min { get; set; }
        public int Max { get; set; }
        public DateTime Date { get; set; }
        public string Status { get; set; }
        public string Client { get; set; }
        public string QuoteType { get; set; }
        public double QuoteValue { get; set; }
    }



    private List<string> JobTypes { get; set; } = new();
    private List<string> SelectedJobType { get; set; } = new();

    private List<string> JobStatuses { get; set; } = new();
    private List<string> SelectedJobStatus { get; set; } = new();



    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await GetQuoteData();

        StateHasChanged(); // force refresh when data is ready
    }

    private void OpenQuoteRecord()
    {

    }




    /// <summary>
    /// Loads up the quote records from the database.
    /// </summary>
    private async Task GetQuoteData()
    {
        try
        {
            var records = await coreClient.GetQuoteDashboardDataAsync(new GetQuoteDashboardDataReq());

            if(records.Res.Any())
            {


                foreach(var rec in records.Res)
                {
                    if(rec.QuoteType != "")
                    {
                        var chartData = new QuoteChartData
                        {
                            QuoteID = rec.QuoteID,
                            QuoteNumber = rec.QuoteNumber,
                            Guid = rec.Guid,
                            Date = rec.Date.ToDateTime(),
                            Client = rec.Client,
                            QuoteType = rec.QuoteType,
                            Status = rec.Status,
                            QuoteValue = rec.QuoteValue,
                            Max = GetMax(rec.QuoteValue),
                            Min = GetMin(rec.QuoteValue)
                            };

                        ChartData.Add(chartData);
                    }
                }

                Console.WriteLine($"GetQuoteData -> Loaded {ChartData.Count} records");

                FilterChart();
            }
        }
        catch (Exception ex)
        {
            //TODO: Handle it properly
            Console.WriteLine(ex.Message);
        }
    }


    /// <summary>
    /// Filters down the data set based on the filters applied.
    /// This is also the function where we assign the data to the chart.
    /// </summary>
    private void FilterChart()
    {
        // Step 1: Filter the base ChartData by date range and value range
       RangedData = ChartData
        .Where(d => d.Date >= StartDate && d.Date <= EndDate)
        .Where(d => d.Max <= ValueFilter)
        .Select(d => new FilteredQuoteChartData
        {
            QuoteID = d.QuoteID,
            Quotes = new List<QuoteInfo> { new QuoteInfo(d.QuoteNumber, d.Guid) },
            Label = GetTimeGroupLabel(d.Date),
            Value = d.Value,
            Min = d.Min,
            Max = d.Max,
            Date = d.Date,
            Status = d.Status,
            Client = d.Client,
            QuoteType = d.QuoteType,
            QuoteValue = d.QuoteValue
        })
        .ToList();

        // Step 2: Build distinct job types and statuses for dropdowns
        JobTypes = RangedData
            .Select(x => x.QuoteType)
            .Distinct()
            .OrderBy(x => x)
            .ToList();

        JobStatuses = RangedData
            .Select(y => y.Status)
            .Distinct()
            .OrderBy(y => y)
            .ToList();
    }





    private async Task SetChartData(List<string> JobType)
{
    // Assign the selection
    SelectedJobType = JobType;

    var rangeFiltered = RangedData;

    if (!JobType.Any())
    {
        rangeFiltered = new List<FilteredQuoteChartData>();
    }
    else
    {
        // Filter the base data
        rangeFiltered = rangeFiltered
            .Where(x => SelectedJobType.Contains(x.QuoteType))
            .Where(y => SelectedJobStatus.Contains(y.Status))
            .ToList();

        // Reset the records-per-type dictionary
        NumberOfRecordsPerType = new();

        List<FilteredQuoteChartData> grouped = rangeFiltered
            .GroupBy(r => new { r.Status, r.QuoteType, r.Label })
            .Select(g => new FilteredQuoteChartData
            {
                Status = g.Key.Status,
                QuoteType = g.Key.QuoteType,
                Label = g.Key.Label,
                Date = g.First().Date,
                Client = g.First().Client,
                QuoteID = g.First().QuoteID,
                Value = g.Count(), // number of records
                QuoteValue = g.Average(x => x.QuoteValue),

                //Merge all quote numbers into one list.
              Quotes = g.SelectMany(x => x.Quotes)
              .Distinct()
              .ToList()

            })
            .ToList();

        // Build dictionary of record counts
        foreach (var rec in grouped)
        {
            var combinedLabel = $"{rec.Status} - {rec.QuoteType} - {rec.Label}";
            NumberOfRecordsPerType[combinedLabel] = rec.Value;
        }

        FilteredChartData = grouped.OrderBy(q => q.Date).ToList();
    }

    // ===== Update KPI Figures =====
    DateRangeTotal = (decimal)FilteredChartData.Sum(q => q.QuoteValue);
    DateRangeAverage = (decimal)(FilteredChartData.Any() ? FilteredChartData.Average(r => r.QuoteValue) : 0);
    DateRangeAboveFiftyK = (int)FilteredChartData
        .Where(r => r.QuoteValue > 50000)
        .Sum(r => r.QuoteValue);

    QuotesSent = FilteredChartData.Count(q => q.Status == "Sent");
    QuotesAccepted = FilteredChartData.Count(q => q.Status == "Accepted");
    QuotesRejected = FilteredChartData.Count(q => q.Status == "Rejected");

    TotalQuoteValue = DateRangeTotal;
    AverageQuoteValue = DateRangeAverage;
    QuotesAboveFiftyKCount = FilteredChartData.Count(q => q.QuoteValue > 50000);
    PercentageAboveFiftyK = FilteredChartData.Any()
        ? (int)((QuotesAboveFiftyKCount / (decimal)FilteredChartData.Count) * 100)
        : 0;

    await Task.Delay(200);
    StateHasChanged();
}


    /// <summary>
    /// Event that fires when the user clicks a chart item.
    /// </summary>
    /// <param name="args">CharSeriesClickEventArgs</param>
    private void OnChartClick(ChartSeriesClickEventArgs args)
    {
        Console.WriteLine($"ChartSeriesClickEventArgs args =>  {args.ToString}");
    }



    /// <summary>
    /// Custom method to rebind the chart.
    /// </summary>
    private void RebindChart()
    {
        FilterChart();
        _ = Task.Run(async () => SetChartData(SelectedJobType));
    }


/*
 *  =================================================================
 *  =                                                               =
 *  =                       CHART LABELS                            =
 *  =                                                               =
 *  =================================================================
 */


    private int GetMax(double quoteValue)
    {
        if (quoteValue <= 25000)
            return 25000;
        else if (quoteValue <= 50000)
            return 50000;
        else if (quoteValue <= 75000)
            return 75000;
        else
            return int.MaxValue; // For anything above 75K
    }

    private int GetMin(double quoteValue)
    {
        if (quoteValue <= 25000)
            return 0;
        else if (quoteValue <= 50000)
            return 25001;
        else if (quoteValue <= 75000)
            return 50001;
        else
            return 75001; // For anything above 75K
    }


    private string GetColorForQuoteType(string quoteType)
    {
        if (!QuoteTypeColors.ContainsKey(quoteType))
        {
            var color = $"#{rand.Next(0x1000000):X6}"; // Random HEX color
            QuoteTypeColors[quoteType] = color;
        }
        return QuoteTypeColors[quoteType];
    }


    private string GetColorForStatus(string status)
    {
        if (!QuoteStatusColors.ContainsKey(status))
        {
            var color = $"#{rand.Next(0x1000000):X6}";
            QuoteStatusColors[status] = color;
        }
        return QuoteStatusColors[status];
    }


    private string GetTimeGroupLabel(DateTime date)
    {
        return Grouping switch
        {
            TimeGrouping.Daily => date.ToString("dd MMM"),
            TimeGrouping.Weekly => $"Week {CultureInfo.CurrentCulture.Calendar.GetWeekOfYear(date, CalendarWeekRule.FirstDay, DayOfWeek.Monday)}",
            TimeGrouping.Monthly => date.ToString("MMM yyyy"),
            _ => date.ToString("dd MMM")
        };
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JsRuntime.InvokeVoidAsync("setTimeout", "window.dispatchEvent(new Event('resize'))", 150);
        }
    }


   /*
    *  =================================================================
    *  =                                                               =
    *  =            FILTER + DATE CHANGE EVENTS                        =
    *  =                                                               =
    *  =================================================================
    */
    private void OnStartDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var result))
        {
            StartDate = result;
            DebounceFilter();
        }
    }

    private void OnEndDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var result))
        {
            EndDate = result;
            DebounceFilter();
        }
    }

    private void OnValueFilterChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var value))
        {
            ValueFilter = value;
            RebindChart();
        }
    }

    private void DebounceFilter()
    {
        filterDebounceTimer?.Dispose();
        filterDebounceTimer = new Timer(async _ =>
        {
            await InvokeAsync(() =>
            {
                FilterChart();
                StateHasChanged();
            });
        }, null, 200, Timeout.Infinite);
    }

    private void OnFilterChanged(object value)
    {
        FilterChart();
    }




    /*
     *  =================================================================
     *  =                                                               =
     *  =                EXPORT FUNCTIONALITY                           =
     *  =                                                               =
     *  =================================================================
     */
    private async Task ExportToCsv()
    {
        var csv = new StringBuilder();
        csv.AppendLine("Label,Min,Max,Value,Date");
        foreach (var item in FilteredChartData)
        {
            csv.AppendLine($"{item.Label},{item.Min},{item.Max},{item.Value},{item.Date:yyyy-MM-dd}");
        }

        var bytes = Encoding.UTF8.GetBytes(csv.ToString());
        var base64 = Convert.ToBase64String(bytes);
        await JsRuntime.InvokeVoidAsync("BlazorDownloadFile", "quote_data.csv", "text/csv", base64);
    }

    private async Task ExportToPdf()
    {
        var pdfContent = $"Quote Dashboard\nDate Range: {StartDate:d} - {EndDate:d}\n\n" +
                         string.Join("\n", FilteredChartData.Select(q => $"{q.Label}: {q.Value} quotes"));
        var bytes = Encoding.UTF8.GetBytes(pdfContent);
        var base64 = Convert.ToBase64String(bytes);
        await JsRuntime.InvokeVoidAsync("BlazorDownloadFile", "quote_data.pdf", "application/pdf", base64);
    }
}

