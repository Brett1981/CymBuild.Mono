@page "/WorkflowDetail/{RecordGuid}/{SerializedDataObjectReference}/{ReturnUrl}"
@inherits EditPageBase
@attribute [Authorize]
@using Concursus.API.Client.Models;
@using Google.Protobuf.WellKnownTypes
@using Microsoft.AspNetCore.Components;


<EditPage @ref="@editPage"
          EntityTypeGuid="672f7b76-a422-4a80-8d89-43d4514b2511"
          Windowed="@Windowed"
          @bind-RecordGuid="@RecordGuid"
          @bind-ParentDataObjectReference="@ParentDataObjectReference"
          ReturnUrl="@ReturnUrl"
          ModalId="@ModalId"
          CloseWindow="@CloseWindow"
          GridUpdated="@GridUpdated"
          IsDetailWindowed="IsDetailWindowed" TransientVirtualProperties="@TransientVirtualProperties">
    <FormTitle>
        <i class="bi bi-building me-2" style="font-size: 1.2rem;"></i>
    </FormTitle>
    <FormBody>
        <TelerikTabStrip TabPosition="TabPosition.Top" PersistTabContent="true">

            <TabStripTab Title="Your Workflows">
                <HeaderTemplate>
                    <i class="bi bi-briefcase me-2" style="font-size: 1.2rem;"></i> Workflows
                </HeaderTemplate>
                <Content>
                    <FlexPropertyGroups @ref="@editPage.flexPropertyGroups"
                                        entityProperties="@editPage.entityProperties"
                                        entityPropertyGroups="@editPage.entityPropertyGroups"
                                        IsMainRecordContext="@IsMainRecordContext"
                                        dataObject="@editPage.dataObject"
                                        RecordGuid="@RecordGuid"
                                        inputUpdated="@editPage.HandleInputUpdated"
                                        editPageRef="@editPage" />

                    <DynamicGrid GridCode="WORKFLOWTRANS" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />

                </Content>
            </TabStripTab>

            <TabStripTab Title="Workflow Statuses">
                <HeaderTemplate>
                    <i class="bi bi-briefcase me-2" style="font-size: 1.2rem;"></i> Workflow Statuses
                </HeaderTemplate>
                <Content>
                    <DynamicGrid GridCode="WORKFLOWSTATUS"
                                 DrawerGuid="@DrawerGuid"
                                 FullGrid="true"
                                 TransientVirtualProperties="@TransientVirtualProperties" />
                </Content>
            </TabStripTab>

            <TabStripTab Title="Workflow Authorisation">
                <HeaderTemplate>
                    <i class="bi bi-briefcase me-2" style="font-size: 1.2rem;"></i> Workflow Authorisation
                </HeaderTemplate>
                <Content>
                    <DynamicGrid GridCode="WORKFLOWAUTH"
                                 DrawerGuid="@DrawerGuid"
                                 FullGrid="true"
                                 TransientVirtualProperties="@TransientVirtualProperties" />
                </Content>
            </TabStripTab>
        </TelerikTabStrip>
    </FormBody>
</EditPage>


@code {
    [Parameter] public bool IsDetailWindowed { get; set; } = false;
    [Parameter] public string? ModalId { get; set; }

    [Parameter]
    public EventCallback<Exception> OnError { get; set; }

    [Parameter]
    public EventCallback<DataObjectReference> ParentDataObjectReferenceChanged { get; set; }

    [Parameter]
    public string? SerializedDataObjectReference { get; set; }
    [Parameter] public bool IsMainRecordContext { get; set; } = true;
    [Parameter]
    public Dictionary<string, Any> TransientVirtualProperties { get; set; } = new();





    public string DrawerGuid { get; set; } = "";

    //private bool isLoading { get; set; } = true;
}