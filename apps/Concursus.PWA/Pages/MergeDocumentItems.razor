@page "/MergeDocumentItems/{RecordGuid}/{SerializedDataObjectReference}/{ReturnUrl}"
@using Concursus.API.Client.Models
@using Google.Protobuf.WellKnownTypes
@using Newtonsoft.Json
@using System.Web
@inherits EditPageBase

@attribute [Authorize]

<EditPage @ref="@editPage"
          EntityTypeGuid="3cc45d56-b759-4048-8f14-025275dc4326"
          Windowed="@Windowed"
          @bind-RecordGuid="@RecordGuid"
          ModalId="@ModalId"
          @bind-ParentDataObjectReference="@ParentDataObjectReference"
          ReturnUrl="@ReturnUrl"
          CloseWindow="@CloseWindow"
          GridUpdated="@GridUpdated"
          IsDetailWindowed="IsDetailWindowed"
          TransientVirtualProperties="@TransientVirtualProperties">
    <FormTitle>
        <i class="bi bi-file-spreadsheet me-2" style="font-size: 1.2rem;"></i>
    </FormTitle>
    <FormBody>
        <TelerikTabStrip TabPosition="TabPosition.Top" PersistTabContent="true">
            <TabStripTab Title="Merge Documents">
                <HeaderTemplate>
                    <i class="bi bi-file-spreadsheet me-2" style="font-size: 1.2rem;"></i> Merge Document Items
                </HeaderTemplate>
                <Content>
                <FlexPropertyGroups @ref="@editPage.flexPropertyGroups"
                                    entityProperties="@editPage.entityProperties"
                                    entityPropertyGroups="@editPage.entityPropertyGroups"
                                        IsMainRecordContext="@IsMainRecordContext"
                                    dataObject="@editPage.dataObject"
                                    RecordGuid="@RecordGuid"
                                    inputUpdated="@editPage.HandleInputUpdated" />

                    <DynamicGrid GridCode="MERGEDOCITEMINCL" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />
                </Content>
        </TabStripTab>
        <TabStripTab Title="Merge Fields">
            <HeaderTemplate>
                <i class="bi bi-diagram-3 me-2" style="font-size: 1.2rem;"></i> Merge Fields
            </HeaderTemplate>
            <Content>
                    <DynamicGrid GridCode="MERGEDOCUMENTITEMSFIELDS" FullGrid="true" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />
            </Content>
        </TabStripTab>
        </TelerikTabStrip>
    </FormBody>
</EditPage>

@code {
    [Parameter]
    public string? SerializedDataObjectReference { get; set; }
    [Parameter] public string? ModalId { get; set; }
    [Parameter]
    public EventCallback<DataObjectReference> ParentDataObjectReferenceChanged { get; set; }
    [Parameter]
    public EventCallback<Exception> OnError { get; set; }
    [Parameter] public bool IsDetailWindowed { get; set; } = false;
    [Parameter] public bool IsMainRecordContext { get; set; } = true;
    [Parameter]
    public Dictionary<string, Any> TransientVirtualProperties { get; set; } = new();

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            if (ParentDataObjectReference != null)
            {
                ParentDataObjectReference = JsonConvert.DeserializeObject<DataObjectReference>(HttpUtility.UrlDecode(SerializedDataObjectReference) ?? string.Empty);
                await ParentDataObjectReferenceChanged.InvokeAsync(ParentDataObjectReference);
            }
            await base.OnParametersSetAsync();
        }
        catch (Exception ex)
        {
            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Error);
            ex.Data.Add("Message", "An error occurred while setting parameters on Merge Document Items");
            ex.Data.Add("PageMethod", "MergeDocuments/OnParametersSetAsync()");
            _ = OnError.InvokeAsync(ex);
        }

    }
    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var test = editPage;
        }
        return base.OnAfterRenderAsync(firstRender);
    }
}