@page "/BulkRecordChange"
@using Concursus.API.Client.Models
@using Concursus.PWA.Classes
@using Google.Protobuf
@using Google.Protobuf.WellKnownTypes
@using Newtonsoft.Json
@using System.Web
@using System.Dynamic
@inherits EditPageBase
@inject Core.CoreClient coreClient
@inject UserService userService
@inject IJSRuntime JsRuntime
@inject Sage200Microservice.API.Protos.Invoice.InvoiceService.InvoiceServiceClient sageIntegrationService

@attribute [Authorize]

<EditPage @ref="@editPage"
          EntityTypeGuid="@_EntityTypeGuid"
          Windowed="@Windowed"
          @bind-RecordGuid="@RecordGuid"
          ModalId="@ModalId"
          @bind-ParentDataObjectReference="@ParentDataObjectReference"
          ReturnUrl="@ReturnUrl"
          CloseWindow="@CloseWindow"
          GridUpdated="@GridUpdated"
          IsDetailWindowed="IsDetailWindowed"
          IsBulkUpdate="IsBulkUpdate"
          TransientVirtualProperties="@TransientVirtualProperties">
    <FormTitle>
        <i class="bi bi-briefcase-fill me-2" style="font-size: 1.2rem;"></i>
    </FormTitle>
    <FormBody>
        <FlexPropertyGroups @ref="@editPage.flexPropertyGroups"
                            entityProperties="@filteredEntityProperties"
                            entityPropertyGroups="@editPage.entityPropertyGroups"
                            IsMainRecordContext="@IsMainRecordContext"
                            dataObject="@editPage.dataObject"
                            RecordGuid="@RecordGuid"
                            inputUpdated="@HandleInputUpdated"
                            IsBulkUpdate="true" />
    </FormBody>

    <!-- Buttons for Confirm and Cancel -->
    <FormButtons>
        <button class="btn btn-danger" @onclick="CloseModal">Cancel</button>
        <button class="btn btn-success" @onclick="ConfirmChanges">Confirm</button>
    </FormButtons>
</EditPage>
<!-- Loading Overlay -->
@if (IsProcessing)
{
    <div class="overlay">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p>Processing changes, please wait...</p>
    </div>
}
<style>
    .modal-footer {
        padding-top: 1rem;
        border-top: 1px solid #ddd;
    }

        .modal-footer .btn {
            min-width: 100px;
        }

    .overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255, 255, 255, 0.8);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        z-index: 1050;
    }

    .spinner-border {
        width: 3rem;
        height: 3rem;
    }
</style>

@code {
    [Parameter] public string? ModalId { get; set; }
    [Parameter] public EventCallback<Exception> OnError { get; set; }
    [Parameter] public bool IsDetailWindowed { get; set; } = false;
    [Parameter] public List<ExpandoObject> SelectedItems { get; set; } = new List<ExpandoObject>();
    [Parameter] public EventCallback<DataObjectReference> ParentDataObjectReferenceChanged { get; set; }
    [Parameter] public string? SerializedDataObjectReference { get; set; }
    [Parameter] public bool IsBulkUpdate { get; set; } = false;
    [Parameter] public bool IsMainRecordContext { get; set; } = true;
    [Parameter]
    public Dictionary<string, Any> TransientVirtualProperties { get; set; } = new();

    private string _EntityTypeGuid = Guid.Empty.ToString();
    private List<EntityProperty> filteredEntityProperties = new();
    private EntityType EntityTypeProperties = new();
    private FlexPropertyGroup FlexPropertyGroup { get; set; }
    private bool IsProcessing { get; set; } = false;

    //Here, we set the new values for the entity properties
    private Dictionary<string, Any> ValuesToSet { get; set; } = new Dictionary<string, Any>();

    // Store the changes to be applied
    private Dictionary<string, object> ChangesToApply = new();

    private async Task ConfirmChanges()
    {
        string userEmail = "";
        var formHelper = new API.Client.FormHelper(coreClient, sageIntegrationService, PWAFunctions.ParseAndReturnEmptyGuidIfInvalid(EntityTypeGuid).ToString(), userService);

        // Display confirmation dialog
        bool isConfirmed = await JsRuntime.InvokeAsync<bool>("confirm", "Are you sure you wish to perform the selected changes?");
        if (!isConfirmed)
            return;

        IsProcessing = true; // Show the loading overlay
        StateHasChanged();

        try
        {
            if (ValuesToSet.Count == 0)
            {
                await JsRuntime.InvokeVoidAsync("alert", "No changes selected for bulk update.");
                return;
            }


            // Loop through selected records and apply changes
            foreach (var selection in SelectedItems)
            {
                var selectionId = GetRecordGuidFromSelection(selection);
                if (selectionId == Guid.Empty) continue;

                var dataObject = await formHelper.ReadDataObjectAsync(selectionId.ToString(), ParentDataObjectReference);
                if (dataObject == null) continue;


                foreach (var newValue in ValuesToSet)
                {
                    var entityGuid = newValue.Key;
                    var entity = dataObject.DataProperties.FirstOrDefault(x => x.EntityPropertyGuid == entityGuid);

                    //If no entity is returned, it means the property is not present.
                    if (entity != null)
                    {

                         /*
                         *         ==============================================
                         *         ================[OE: CBLD-471]================
                         *         ==============================================
                         *
                         * Check for read-only: due to the implementation of CBLD-92, if there are restrictions
                         * applied to a user or a group, the fields become read-only - same with just read-only fields.
                        */
                        bool IsEntityReadOnly = entity.IsReadOnly;

                        if (IsEntityReadOnly)
                        {
                            //Skip, we cannot change a read-only value.
                            continue;
                        }
                        //Update the record.
                        else
                        {
                            entity.Value = newValue.Value;
                        }
                    }
                    //No entity property - cannot be changed for the dataobject.
                    else
                    {
                        Console.WriteLine("Entity property was not found.");
                    }

                }

                await formHelper.UpsertDataObject(dataObject, null, false);
            }

            await GridUpdated.InvokeAsync();
            CloseModal();


        }
        catch (Exception ex)
        {
            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Error);
            ex.Data.Add("AdditionalInfo", "An error occurred while confirming the changes.");
            ex.Data.Add("PageMethod", "BulkRecordChange/ConfirmChanges()");
            await OnError.InvokeAsync(ex);
        }
        finally
        {
            IsProcessing = false; // Hide the loading overlay
            StateHasChanged();
        }
    }


    private Guid GetRecordGuidFromSelection(ExpandoObject selection)
    {
        if (selection == null)
            return Guid.Empty;

        var dictionary = selection as IDictionary<string, object>;
        if (dictionary != null && dictionary.ContainsKey("Guid"))
        {
            return PWAFunctions.ParseAndReturnEmptyGuidIfInvalid(dictionary["Guid"]?.ToString() ?? string.Empty);
        }

        return Guid.Empty;
    }

    private void CloseModal()
    {
        CloseWindow.InvokeAsync();
        GridUpdated.InvokeAsync();
        StateHasChanged();
    }
    protected override async Task OnParametersSetAsync()
    {
        try
        {
            if (ParentDataObjectReference != null)
            {
                ParentDataObjectReference = JsonConvert.DeserializeObject<DataObjectReference>(HttpUtility.UrlDecode(SerializedDataObjectReference) ?? string.Empty);
                await ParentDataObjectReferenceChanged.InvokeAsync(ParentDataObjectReference);
            }
            _EntityTypeGuid = EntityTypeGuid.ToString();

            // Filter entity properties to show only relevant ones
            await FilterEntityProperties();

            await base.OnParametersSetAsync();
        }
        catch (Exception ex)
        {
            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Error);
            ex.Data.Add("AdditionalInfo", "An error occurred while setting the parameters for the Bulk Record Change page.");
            ex.Data.Add("PageMethod", "BulkRecordChange/OnParametersSetAsync()");
            _ = OnError.InvokeAsync(ex);
        }
    }

    private async Task FilterEntityProperties()
    {
        try
        {
            // Use FormHelper to get entity type properties
            var formHelper = new API.Client.FormHelper(coreClient, sageIntegrationService, _EntityTypeGuid, userService);
            EntityTypeProperties = await formHelper.GetEntityType();

            // List of property GUIDs that are allowed for bulk changes
            List<string> fieldsToShow = new()
            {
                "5bb14d82-b4b4-492e-968a-57e3a8b78596", // TypeGuid
                "0e46fceb-ac8c-4800-9ddc-367d8ad9769c", // AssigneeGuid
                "4014840f-b27e-48b3-8ae4-e700fb4988ba"  // StatusGuid
            };

            // Filter the entity properties based on AllowBulkChange or specific GUIDs
            filteredEntityProperties = EntityTypeProperties.EntityProperties
                .Where(x => x.AllowBulkChange == true || fieldsToShow.Contains(x.Guid.ToString()))
                .ToList();

            // Optionally, load the data object if needed
            //dataObject = await formHelper.ReadDataObjectAsync(RecordGuid, ParentDataObjectReference);
        }
        catch (Exception ex)
        {
            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Error);
            ex.Data.Add("AdditionalInfo", "An error occurred while filtering entity properties for the Bulk Record Change page.");
            ex.Data.Add("PageMethod", "BulkRecordChange/FilterEntityProperties()");
            _ = OnError.InvokeAsync(ex);
        }
    }

    public async void HandleInputUpdated(InputUpdatedArgs inputUpdatedArgs)
    {
        try
        {
            var entityGuid = inputUpdatedArgs.EntityId.ToString();
            var newValue = inputUpdatedArgs.NewValue;
            var typeUrl = newValue.TypeUrl;

            // Determine if the key already exists in the dictionary
            if (ValuesToSet.ContainsKey(entityGuid))
            {
                // Update the existing value
                ValuesToSet[entityGuid] = newValue;
            }
            else
            {
                // Add a new value
                ValuesToSet.Add(entityGuid, newValue);
            }

            // Handle specific types for unpacking or validation
            switch (typeUrl)
            {
                case "type.googleapis.com/google.protobuf.Timestamp":
                    if (newValue.TryUnpack(out Timestamp timestampValue))
                    {
                        Console.WriteLine($"Timestamp unpacked: {timestampValue}");
                    }
                    break;

                case "type.googleapis.com/google.protobuf.Int32Value":
                    if (newValue.TryUnpack(out Int32Value int32Value))
                    {
                        Console.WriteLine($"Int32 unpacked: {int32Value.Value}");
                    }
                    break;

                case "type.googleapis.com/google.protobuf.Int64Value":
                    if (newValue.TryUnpack(out Int64Value int64Value))
                    {
                        Console.WriteLine($"Int64 unpacked: {int64Value.Value}");
                    }
                    break;

                case "type.googleapis.com/google.protobuf.StringValue":
                    if (newValue.TryUnpack(out StringValue stringValueObj))
                    {
                        Console.WriteLine($"String unpacked: {stringValueObj.Value}");
                    }
                    break;

                case "type.googleapis.com/google.protobuf.BoolValue":
                    if (newValue.TryUnpack(out BoolValue boolValue))
                    {
                        Console.WriteLine($"Boolean unpacked: {boolValue.Value}");
                    }
                    break;

                case "type.googleapis.com/google.protobuf.DoubleValue":
                    if (newValue.TryUnpack(out DoubleValue doubleValue))
                    {
                        Console.WriteLine($"Double unpacked: {doubleValue.Value}");
                    }
                    break;

                case "type.googleapis.com/google.protobuf.FloatValue":
                    if (newValue.TryUnpack(out FloatValue floatValue))
                    {
                        Console.WriteLine($"Float unpacked: {floatValue.Value}");
                    }
                    break;

                case "type.googleapis.com/google.protobuf.BytesValue":
                    if (newValue.TryUnpack(out BytesValue bytesValue))
                    {
                        Console.WriteLine($"Bytes unpacked: {BitConverter.ToString(bytesValue.Value.ToByteArray())}");
                    }
                    break;

                default:
                    // Treat unhandled types as strings
                    var defaultValue = newValue.Value.ToStringUtf8();
                    Console.WriteLine($"Unhandled type treated as string: {defaultValue}");

                    // Update ValuesToSet with the string value
                    ValuesToSet[entityGuid] = new Any
                        {
                            Value = ByteString.CopyFromUtf8(defaultValue)
                        };
                    break;
            }

            // Rebind properties in the UI to reflect changes
            FlexPropertyGroup.RebindFromPropertyChange(inputUpdatedArgs);

            Console.WriteLine("Updated ValuesToSet:");
            foreach (var value in ValuesToSet)
            {
                Console.WriteLine($"Key: {value.Key}, Value: {value.Value}");
            }
        }
        catch (Exception ex)
        {
            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Error);
            ex.Data.Add("AdditionalInfo", "An error occurred while handling input updates.");
            ex.Data.Add("PageMethod", "HandleInputUpdated");
            await OnError.InvokeAsync(ex);
        }
    }




}