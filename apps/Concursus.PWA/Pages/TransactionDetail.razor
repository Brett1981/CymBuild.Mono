@page "/TransactionDetail/{RecordGuid}/{SerializedDataObjectReference}/{ReturnUrl}"
@using Concursus.API.Client.Models
@using Google.Protobuf.WellKnownTypes
@using Newtonsoft.Json
@using System.Web
@inherits EditPageBase

@attribute [Authorize]

<EditPage @ref="@editPage"
          EntityTypeGuid="3679db86-9a2f-45bd-9e37-8e40967166d1"
          Windowed="@Windowed"
          @bind-RecordGuid="@RecordGuid"
          ModalId="@ModalId"
          @bind-ParentDataObjectReference="@ParentDataObjectReference"
          ReturnUrl="@ReturnUrl"
          CloseWindow="@CloseWindow"
          GridUpdated="@GridUpdated"
          IsDetailWindowed="@IsDetailWindowed"
          TransientVirtualProperties="@TransientVirtualProperties">
    <FormTitle>
        <i class="bi bi-briefcase-fill me-2" style="font-size: 1.2rem;"></i>
    </FormTitle>
    <FormBody>
        <TelerikTabStrip TabPosition="TabPosition.Top" PersistTabContent="true">
            <TabStripTab Title="Transactions">
                <HeaderTemplate>
                    <i class="bi-receipt me-2" style="font-size: 1.2rem;"></i> Transactions
                </HeaderTemplate>
                <Content>
                    <div class="row">
                        <JobProgress DataObject="@editPage.dataObject"/>
                    </div>
                    <div class="row">
                        <FlexPropertyGroups @ref="@editPage.flexPropertyGroups"
                                            entityProperties="@editPage.entityProperties"
                                            entityPropertyGroups="@editPage.entityPropertyGroups"
                                            IsMainRecordContext="@IsMainRecordContext"
                                            dataObject="@editPage.dataObject"
                                            RecordGuid="@RecordGuid"
                                            inputUpdated="@editPage.HandleInputUpdated"/>

                    </div>
                    <div class="row">
                        <DynamicGrid GridCode="TRANSACTIONDETAILS" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />
                        <DynamicGrid GridCode="TRANSACTIONFINANCEMEMO" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference"
                                     ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />
                    </div>

                </Content>
            </TabStripTab>
            <TabStripTab Title="Allocations">
                <HeaderTemplate>
                    <i class="bi bi-cash-stack me-2" style="font-size: 1.2rem;"></i> Allocations
                </HeaderTemplate>
                <Content>
                    <DynamicGrid GridCode="TRANSACTIONALOCATIONS" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference"
                                 ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />
                </Content>
            </TabStripTab>

        </TelerikTabStrip>

    </FormBody>
</EditPage>

<style>
    .bg-orange{
        background-color: orange;
    }
</style>

@code {
    [Parameter] public string? SerializedDataObjectReference { get; set; }
    [Parameter] public string? ModalId { get; set; }
    [Parameter] public EventCallback<DataObjectReference> ParentDataObjectReferenceChanged { get; set; }
    [Parameter] public EventCallback<Exception> OnError { get; set; }
    [Parameter] public bool IsDetailWindowed { get; set; } = false;
    [Parameter] public bool IsMainRecordContext { get; set; } = true;
    [Parameter] public Dictionary<string, Any> TransientVirtualProperties { get; set; } = new();

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            if (ParentDataObjectReference != null)
            {
                ParentDataObjectReference = JsonConvert.DeserializeObject<DataObjectReference>(HttpUtility.UrlDecode(SerializedDataObjectReference) ?? string.Empty);
                await ParentDataObjectReferenceChanged.InvokeAsync(ParentDataObjectReference);
            }

            await base.OnParametersSetAsync();
        }
        catch (Exception ex)
        {
            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Error);
            ex.Data.Add("AdditionalInfo", "An error occurred while setting the parameters for the TransactionDetail page.");
            ex.Data.Add("PageMethod", "TransactionDetail/OnParametersSetAsync()");
            _ = OnError.InvokeAsync(ex);
        }
    }

}