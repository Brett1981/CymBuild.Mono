    private async Task UpdateQuotes()
    {
        try
        {
            // Clear the previous log output
            logOutputBuilder.Clear();
            logOutput = string.Empty;

            // Get GridDataList from GridRef
            GridDataListRequest gridDataListRequest = new()
                {
                    GridCode = "QUOTES",
                    GridViewCode = "ALLQUOTES",
                    ParentGuid = PWAFunctions.ParseAndReturnEmptyGuidIfInvalid("00000000-0000-0000-0000-000000000000").ToString()
                };

            var gridDataListReply = await coreClient.GridDataListAsync(gridDataListRequest);
            if (gridDataListReply.TotalRows > 0)
            {
                var dataObjectGetRequest = new DataObjectGetRequest()
                    {
                        EntityTypeGuid = PWAFunctions.ParseAndReturnEmptyGuidIfInvalid("1c4794c1-f956-4c32-b886-5500ac778a56").ToString(),
                        ForInformationView = false
                    };
                // Get the list of existing SharePoint folders
                var ospResponse = await coreClient.ObjectSharePointPathCollectionGetAsync(new ObjectSharePointPathCollectionGetRequest());

                // Create a HashSet of GUIDs from the ospResponse for fast lookup
                var existingGuids = new HashSet<string>(ospResponse.ObjectSharePointPaths.Select(o => o.ObjectGuid));

                foreach (var gridDataRow in gridDataListReply.DataTable)
                {
                    var objectGuid = gridDataRow.Columns[1].Value.ToString(); // Assuming column 1 contains the Guid

                    // Skip processing if the objectGuid exists in ospResponse
                    if (existingGuids.Contains(objectGuid))
                    {
                        // Log the record as being skipped to the logOutputBuilder
                        logOutputBuilder.AppendLine($"Skipping Record: {objectGuid} As already exists");

                        // Update the UI
                        logOutput = logOutputBuilder.ToString();
                        StateHasChanged();
                        // Scroll to the bottom
                        await ScrollToBottom();
                        continue; // Skip this iteration
                    }

                    // Find the "Number" column in the row
                    var numberColumn = gridDataRow.Columns.FirstOrDefault(c => c.Name == "Number");

                    // Check if the "Number" column exists and its value is numeric
                    if (numberColumn != null && !numberColumn.Value.Contains("SHORE"))
                    {
                        // Process each ObjectGuid individually
                        dataObjectGetRequest.ObjectGuids.Clear();
                        dataObjectGetRequest.ObjectGuids.Add(objectGuid);

                        // Call the API and process each object
                        var response = await coreClient.DataObjectListGetSingleAsync(dataObjectGetRequest);

                        foreach (var dataObject in response.DataObjects)
                        {
                            // Log the Guid and SharePointUrl to the logOutputBuilder
                            logOutputBuilder.AppendLine($"Record: {dataObject.Label}, SharePointUrl: {dataObject.SharePointUrl}");

                            // Update the UI
                            logOutput = logOutputBuilder.ToString();
                            StateHasChanged();
                            // Scroll to the bottom
                            await ScrollToBottom();
                        }
                    }
                }

                logOutputBuilder.AppendLine("All items processed successfully.");
                logOutput = logOutputBuilder.ToString();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Error);
            ex.Data.Add("AdditionalInfo", "An error occurred while updating Quotes.");
            ex.Data.Add("PageMethod", "DetailView/UpdateQuotes()");
            _ = OnError.InvokeAsync(ex);
        }
    }
