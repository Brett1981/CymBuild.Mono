@page "/dev"
@using Concursus.Components.Shared.Services
@using Concursus.PWA.Classes
@using Concursus.PWA.Pages.Admin.Monitoring
@using Concursus.PWA.Services
@using Concursus.API.Client
@using Concursus.API.Client.Models
@using System.Text
@using Google.Protobuf.WellKnownTypes
@inject OfflineSyncService SyncService
@inject Core.CoreClient coreClient
@inject UserService userService
@inject IJSRuntime jsRuntime
@inject AiErrorReporter AiErrorReporter
@inject IToastService Toast

@attribute [Authorize]

<Concursus.PWA.Shared.MessageDisplay @ref="messageDisplay" />
<h4><i class="bi bi-code me-2" style="font-size: 1.2rem;"></i> Development</h4>

<TelerikTabStrip TabPosition="TabPosition.Top" PersistTabContent="true">
    <TabStripTab Title="Development">
        <HeaderTemplate>
            <i class="bi bi-code me-2" style="font-size: 1.2rem;"></i> Development
        </HeaderTemplate>
        <Content>
            <div class="row">
                <DynamicGrid GridCode="DEV" FullGrid="true" TransientVirtualProperties="@TransientVirtualProperties" />
            </div>
        </Content>
    </TabStripTab>
    <TabStripTab Title="Dev Advanced">
        <Content>
            <TelerikTabStrip>
                <TabStripTab Title="Routines">
                    <HeaderTemplate>
                        <i class="bi bi-collection-play me-2" style="font-size: 1.2rem;"></i> Routines
                    </HeaderTemplate>
                    <Content>
                        <div class="container mt-3">
                            <div class="row mb-3">
                                <div class="col-md-9">
                                    <label for="routineJobs" class="fw-bold">Update Jobs</label>
                                    <p>This Routine will receive a collection of 'ALL JOBS' DataObjects and run the routines to create the Sharepoint Folders and permissions.</p>
                                </div>
                                <div class="col-md-3 text-end">
                                    <button class="btn btn-primary" @onclick="UpdateJobs">Update Jobs</button>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-9">
                                    <label for="routineEnquiries" class="fw-bold">Update Enquiries</label>
                                    <p>This Routine will receive a collection of 'ALL ENQUIRIES' DataObjects and run the routines to create the Sharepoint Folders and permissions.</p>
                                </div>
                                <div class="col-md-3 text-end">
                                    <button class="btn btn-primary" @onclick="UpdateEnquiries">Update Enquiries</button>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-9">
                                    <label for="routineQuotes" class="fw-bold">Update Quotes</label>
                                    <p>This Routine will receive a collection of 'ALL QUOTES' DataObjects and run the routines to create the Sharepoint Folders and permissions.</p>
                                </div>
                                <div class="col-md-3 text-end">
                                    <button class="btn btn-primary" @onclick="UpdateQuotes">Update Quotes</button>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-9">
                                    <label for="routineAccounts" class="fw-bold">Update Accounts</label>
                                    <p>This Routine will receive a collection of 'ALL CRM ACCOUNTS' DataObjects and run the routines to create the Sharepoint Folders and permissions.</p>
                                </div>
                                <div class="col-md-3 text-end">
                                    <button class="btn btn-primary" @onclick="UpdateAccounts">Update Accounts</button>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-9">
                                    <label for="routineProperties" class="fw-bold">Update Properties</label>
                                    <p>This Routine will receive a collection of 'ALL ASSETS' DataObjects and run the routines to create the Sharepoint Folders and permissions.</p>
                                </div>
                                <div class="col-md-3 text-end">
                                    <button class="btn btn-primary" @onclick="UpdateProperties">Update Properties</button>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-9">
                                    <label for="routineJobs" class="fw-bold">Import Legacy Statuses</label>
                                    <p>Used by the new status management system. This Routine will import the last status for enquiries, quotes, and jobs.</p>
                                </div>
                                <div class="col-md-3 text-end">
                                    <button class="btn btn-primary" @onclick="ImportLegacyStatuses">Import Legacy Statuses</button>
                                </div>
                            </div>

                            <div class="row mt-4">
                                <div class="col">
                                    <textarea id="logOutput" class="form-control" rows="10" readonly @ref="logOutputRef">@logOutput</textarea>
                                </div>
                            </div>
                        </div>
                    </Content>
                </TabStripTab>
                <TabStripTab Title="Translation">
                    <HeaderTemplate>
                        <i class="bi bi-translate me-2" style="font-size: 1.2rem;"></i> Translation
                    </HeaderTemplate>
                    <Content>
                        <label for="routineName">Create new Language definitions - This Routine will receive a collection of 'British English - Labels Text' and generate new content for the new selected Language.</label>
                        <TelerikComboBox TItem="LanguageItemModel"
                                         TValue="string"
                                         Data="@Languages"
                                         TextField="Text"
                                         ValueField="Value"
                                         @bind-Value="@SelectedLanguage"
                                         Placeholder="Select Language">
                        </TelerikComboBox>
                        <button class="btn btn-primary" @onclick="CreateLanguages">Create Languages</button>
                    </Content>
                </TabStripTab>
                <TabStripTab Title="Usage Statistics">
                    <HeaderTemplate>
                        <i class="bi bi-bar-chart me-2" style="font-size: 1.2rem;"></i> Usage Statistics
                    </HeaderTemplate>
                    <Content>
                        <UsageDashboard />
                    </Content>
                </TabStripTab>
                <TabStripTab Title="Memory Diagnostics">
                    <HeaderTemplate>
                        <i class="bi bi-memory me-2" style="font-size: 1.2rem;"></i> Memory Diagnostics
                    </HeaderTemplate>
                    <Content>
                        <Concursus.PWA.Shared.Diagnostics.Memory />
                    </Content>
                </TabStripTab>
                <TabStripTab Title="Wait Stats">
                    <WaitStatsDashboard />
                </TabStripTab>
                <TabStripTab Title="Sage API test">
                    <SageApiTest />
                </TabStripTab>
                <TabStripTab Title="AI Error Admin">
                    <HeaderTemplate>
                        <i class="bi bi-braces me-2" style="font-size: 1.2rem;"></i> AI Error Admin
                    </HeaderTemplate>
                    <Content>
                        <Concursus.PWA.Shared.AiErrorAdmin OnError="HandleAiError" />
                    </Content>
                </TabStripTab>
                <TabStripTab Title="Sync Queue">
                    <HeaderTemplate>
                        <i class="bi bi-upload me-2" style="font-size: 1.2rem;"></i> Sync Queue
                    </HeaderTemplate>
                    <Content>
                        <DevSyncQueueTab />
                    </Content>
                </TabStripTab>
                <TabStripTab Title="Step Logs">
                    <HeaderTemplate>
                        <i class="bi bi-textarea me-2" style="font-size: 1.2rem;"></i> Step Logs
                    </HeaderTemplate>
                    <Content>
                        <DebugInteractions />
                    </Content>
                </TabStripTab>
                <TabStripTab Title="PostCode Lookup">
                    <HeaderTemplate>
                        <i class="bi bi-mailbox-flag me-2" style="font-size: 1.2rem;"></i> PostCode Lookup
                    </HeaderTemplate>
                    <Content>
                        <PostcodeLookupTab />
                    </Content>
                </TabStripTab>
            </TelerikTabStrip>
        </Content>
    </TabStripTab>
</TelerikTabStrip>

<script>
    window.scrollToBottom = function (element) {
        element.scrollTop = element.scrollHeight;
    };
</script>

