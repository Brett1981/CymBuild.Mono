    private async Task ImportLegacyStatuses()
    {
        try
        {

            logOutputBuilder.AppendLine("Importing legacy statuses has started. This might take a few minutes to complete, please wait!");
            logOutput = logOutputBuilder.ToString();
            StateHasChanged();

            var success = await coreClient.ImportLegacyStatusesAsync(new ImportLegacyStatusesReq());

            if (success.Status)
            {
                logOutputBuilder.AppendLine("Imported Legacy Statuses!");
                logOutput = logOutputBuilder.ToString();
                StateHasChanged();
            }
            else
            {
                logOutputBuilder.AppendLine($"There was a problem importing legacy statuses: {success.ErrorReturned}");
                logOutput = logOutputBuilder.ToString();
                StateHasChanged();
            }

        } catch(Exception ex)
        {

        }
    }

