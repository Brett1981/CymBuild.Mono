@page "/AccountDetail/{RecordGuid}/{SerializedDataObjectReference}/{ReturnUrl}"
@inherits EditPageBase

@attribute [Authorize]

<EditPage @ref="@editPage"
          EntityTypeGuid="40476ecc-d19a-4de9-90df-e1f45cd72fb2"
          Windowed="@Windowed"
          @bind-RecordGuid="@RecordGuid"
          @bind-ParentDataObjectReference="@ParentDataObjectReference"
          ReturnUrl="@ReturnUrl"
          ModalId="@ModalId"
          CloseWindow="@CloseWindow"
          GridUpdated="@GridUpdated"
          IsDetailWindowed="IsDetailWindowed"
          EnableBrowserTabTitle="true"
          BrowserTabTitlePropertyName="Name"
          BrowserTabTitlePrefix="Account"
          TransientVirtualProperties="@TransientVirtualProperties">
    <FormTitle>
        <i class="bi bi-briefcase-fill me-2" style="font-size: 1.2rem;"></i>
    </FormTitle>
    <FormBody>
        <TelerikTabStrip TabPosition="TabPosition.Top" PersistTabContent="true">
            <TabStripTab Title="Account">
                <HeaderTemplate>
                    <i class="bi bi-person-vcard me-2" style="font-size: 1.2rem;"></i> Account
                </HeaderTemplate>
                <Content>
                    <FlexPropertyGroups @ref="@editPage.flexPropertyGroups"
                                        entityProperties="@editPage.entityProperties"
                                        entityPropertyGroups="@editPage.entityPropertyGroups"
                                        IsMainRecordContext="@IsMainRecordContext"
                                        dataObject="@editPage.dataObject"
                                        RecordGuid="@RecordGuid"
                                        inputUpdated="@editPage.HandleInputUpdated"/>

                    <DynamicGrid GridCode="ACCOUNTADDRESSES" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />

                    <DynamicGrid GridCode="ACCOUNTCONTACTS" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />

                    <DynamicGrid GridCode="ACCOUNTMEMOS" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />

                </Content>
            </TabStripTab>
            <TabStripTab Title="Finance">
                <HeaderTemplate>
                    <i class="bi bi-bank2 me-2" style="font-size: 1.2rem;"></i> Finance
                </HeaderTemplate>
                <Content>
                    <DynamicGrid GridCode="ACCOUNTTRANSACTIONS" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />
                    <DynamicGrid GridCode="ACCOUNTFINANCEMEMO" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference"
                                 ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />
                    </Content>
            </TabStripTab>
            <TabStripTab Title="Contracts">
                <HeaderTemplate>
                    <i class="bi bi-file-medical-fill me-2" style="font-size: 1.2rem;"></i> Contracts
                </HeaderTemplate>
                <Content>
                    <DynamicGrid GridCode="ACCOUNTCONTRACTS" ParentGuid="@RecordGuid" FullGrid=true ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />

                </Content>
            </TabStripTab>
            <TabStripTab Title="History">
                <HeaderTemplate>
                    <i class="bi bi-book me-2" style="font-size: 1.2rem;"></i> Related Records
                </HeaderTemplate>
                <Content>
                    <DynamicGrid GridCode="ACCOUNTJOBHISTORY" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" TransientVirtualProperties="@TransientVirtualProperties" />
                </Content>
            </TabStripTab>

        </TelerikTabStrip>
    </FormBody>
</EditPage>