@page "/InvoiceRequestDetail/{RecordGuid}/{SerializedDataObjectReference}/{ReturnUrl}"
@using Concursus.API.Client.Models
@using Newtonsoft.Json
@using System.Web
@using Google.Protobuf.WellKnownTypes
@inherits EditPageBase

@attribute [Authorize]

<EditPage @ref="@editPage"
          EntityTypeGuid="27a13441-73c4-425a-8b55-dc048dabe6bb"
          Windowed="@Windowed"
          @bind-RecordGuid="@RecordGuid"
          ModalId="@ModalId"
          @bind-ParentDataObjectReference="@ParentDataObjectReference"
          ReturnUrl="@ReturnUrl"
          CloseWindow="@CloseWindow"
          GridUpdated="@GridUpdated"
          IsDetailWindowed="IsDetailWindowed"
          TransientVirtualProperties="@TransientVirtualProperties">
    <FormTitle>
        <i class="bi bi-person-fill-lock" style="font-size: 1.2rem;"></i>
    </FormTitle>
    <FormBody>

        @if (MergeSuccessMsg != null && MergeSuccessMsg != "")
        {
            <div class="alert alert-success py-2 small">@MergeSuccessMsg</div>
        }


        <FlexPropertyGroups @ref="@editPage.flexPropertyGroups"
                            entityProperties="@editPage.entityProperties"
                            entityPropertyGroups="@editPage.entityPropertyGroups"
                            IsMainRecordContext="@IsMainRecordContext"
                            dataObject="@editPage.dataObject"
                            RecordGuid="@RecordGuid"
                            inputUpdated="@editPage.HandleInputUpdated"/>

        <DynamicGrid GridCode="INVOICEREQUESTITEMS" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />

        <DynamicGrid GridCode="JOBFINANCEMEMO" ParentGuid="@JobFinanceMemoParentGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />
    </FormBody>
</EditPage>

@code {
    [Parameter]
    public string? SerializedDataObjectReference { get; set; }
    [Parameter] public string? ModalId { get; set; }
    [Parameter]
    public EventCallback<DataObjectReference> ParentDataObjectReferenceChanged { get; set; }
    [Parameter]
    public EventCallback<Exception> OnError { get; set; }
    [Parameter] public bool IsDetailWindowed { get; set; } = false;
    [Parameter] public bool IsMainRecordContext { get; set; } = true;
    [Parameter] public string MergeSuccessMsg { get; set; }
    [Parameter]
    public Dictionary<string, Any> TransientVirtualProperties { get; set; } = new();

    private string JobFinanceMemoParentGuid { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            if (ParentDataObjectReference != null)
            {
                ParentDataObjectReference = JsonConvert.DeserializeObject<DataObjectReference>(HttpUtility.UrlDecode(SerializedDataObjectReference) ?? string.Empty);
                await ParentDataObjectReferenceChanged.InvokeAsync(ParentDataObjectReference);
            }


            await base.OnParametersSetAsync();
        }
        catch (Exception ex)
        {
            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Error);
            ex.Data.Add("AdditionalInfo", "An error occurred while setting parameters for the Invoice Request Detail page.");
            ex.Data.Add("PageMethod", "InvoiceRequestDetail/OnParametersSetAsync()");
            _ = OnError.InvokeAsync(ex);
        }
    }


    protected override void OnAfterRender(bool firstRender)
    {
        /*
        *  [CBLD-514]
        *
        * Instead of writing a new table-value function, we simply
         * extract the job guid from the invoice request and then pass it to the grid as the ParentGuid.
         *
         */
        if(!firstRender){
            //Handling for the finance memo grid - we need the jobID.
            if (editPage.dataObject != null)
            {
                var DataObject = editPage.dataObject;
                var JobIdProperty = DataObject.DataProperties.Where(x => x.EntityPropertyGuid == "dddabd42-c753-48fa-800f-a73c88fcadcd").FirstOrDefault();

                if (JobIdProperty != null && JobFinanceMemoParentGuid == null)
                {

                    JobFinanceMemoParentGuid = JobIdProperty.Value.Unpack<StringValue>().Value;
                    StateHasChanged();
                }
            }
        }
        base.OnAfterRender(firstRender);
    }
}