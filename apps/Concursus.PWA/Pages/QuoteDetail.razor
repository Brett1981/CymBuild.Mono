@page "/QuoteDetail/{RecordGuid}/{SerializedDataObjectReference}/{ReturnUrl}"
@using Concursus.API.Client.Models
@using Concursus.Components.Shared.Controls.Documents
@using Concursus.PWA.Classes
@using Google.Protobuf.WellKnownTypes
@using Microsoft.Extensions.Options
@using Newtonsoft.Json
@using System.Web
@inherits EditPageBase

@inject Core.CoreClient coreClient
@inject UserService userService
@inject Sage200Microservice.API.Protos.Invoice.InvoiceService.InvoiceServiceClient sageIntegrationService
@inject IOptions<ClientConfiguration> Config

@attribute [Authorize]

<EditPage @ref="@editPage"
          EntityTypeGuid="1c4794c1-f956-4c32-b886-5500ac778a56"
          Windowed="@Windowed"
          @bind-RecordGuid="@RecordGuid"
          ModalId="@ModalId"
          @bind-ParentDataObjectReference="@ParentDataObjectReference"
          ReturnUrl="@ReturnUrl"
          CloseWindow="@CloseWindow"
          GridUpdated="@GridUpdated"
          IsDetailWindowed="IsDetailWindowed"
          EnableBrowserTabTitle="true"
          BrowserTabTitlePropertyName="Number"
          BrowserTabTitlePrefix="Quote"
          TransientVirtualProperties="@TransientVirtualProperties">
    <FormTitle>
        <i class="bi bi-briefcase-fill me-2" style="font-size: 1.2rem;"></i>
    </FormTitle>
    <FormBody>
         <TelerikTabStrip TabPosition="TabPosition.Top" PersistTabContent="true">
            <TabStripTab Title="Quote Details">
                <HeaderTemplate>
                    <i class="bi bi-briefcase me-2" style="font-size: 1.2rem;"></i> Quote Details
                </HeaderTemplate>
                <Content>
                    <DynamicGrid GridCode="RECORDSTATUS" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" ResyncDataObject="@editPage.ReSyncDataObject" TransientVirtualProperties="@TransientVirtualProperties" />
                    <FlexPropertyGroups @ref="@editPage.flexPropertyGroups"
                            entityProperties="@editPage.entityProperties"
                            entityPropertyGroups="@editPage.entityPropertyGroups"
                                        IsMainRecordContext="@IsMainRecordContext"
                            dataObject="@editPage.dataObject"
                            RecordGuid="@RecordGuid"
                            inputUpdated="@editPage.HandleInputUpdated"/>

                    <DynamicGrid GridCode="QUOTEMEMOS" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />
                    <DynamicGrid GridCode="QUOTEITEMS" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />
                @* <DynamicGrid GridCode="QUOTESECTIONS" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" /> *@


                </Content>
            </TabStripTab>
            <TabStripTab Title="Project Details">
                <HeaderTemplate>
                    <i class="bi bi-person-vcard me-2" style="font-size: 1.2rem;"></i> Project Details
                </HeaderTemplate>
                <Content>
                    <div class="card shadow-sm">
                        <div class="card-header" style="background-color: #17a2b8; color:#ffffff;">
                            <i class="bi bi-info-circle" style=" margin-right: 9px !important; color: #ffffff">  </i>Information
                        </div>
                        <div class="card-body">
                            <p class="card-text">Project Details are shared across all records linked to this project. Changes you make here will be visible on any Enquiry, Quote or Job for this project, even if they belong to a different Business Unit.</p>

                        </div>
                    </div>
                    <DynamicGrid GridCode="QUOTEPROJECTDIRECTORY " ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />
                    <DynamicGrid GridCode="QUOTEKEYDATES" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />
                </Content>
            </TabStripTab>
            <TabStripTab Title="Invoicing">
                <HeaderTemplate>
                    <i class="bi bi-receipt" style="font-size: 1.2rem; margin-right: 5px;"> </i> Invoicing
                </HeaderTemplate>
                <Content>
                    <DynamicGrid GridCode="QUOTEINVOICING" ParentGuid="@RecordGuid" ParentDataObjectReference="@editPage.MyDataObjectReference" ParentRowStatus="@editPage.dataObject.RowStatus" TransientVirtualProperties="@TransientVirtualProperties" />
                </Content>
            </TabStripTab>
            @if (ShowDocumentsTab)
            {
                <TabStripTab Title="Documents">
                    <HeaderTemplate>
                        <i class="bi bi-folder2-open me-2" style="font-size: 1.2rem;"></i> Documents
                    </HeaderTemplate>

                    <Content>
                        <ErrorBoundary @ref="_docsBoundary">
                            <ChildContent>
                                @if (_formHelper is null
                                    || editPage is null
                                    || editPage.dataObject is null
                                    || string.IsNullOrWhiteSpace(editPage.dataObject.Guid)
                                    || editPage.dataObject.Guid == Guid.Empty.ToString())
                                {
                                    <div class="alert alert-info mb-0">
                                        Documents are loading...
                                    </div>
                                }
                                else
                                {
                                    <RecordDocumentBrowserV2 FormHelper="_formHelper"
                                                                DataObject="editPage.dataObject"
                                                                EntityQueryGuid="a29deace-3166-451c-a1ec-0ddf84d0dfa0"
                                                             EntityTypeId="55"
                                                             EntityProperties="editPage.entityProperties"
                                                             EmailRecordNumberPropertyName="Number"
                                                             EmailRecordDescriptionPropertyName="Overview"
                                                             EmailRecordLocationPropertyName="FormattedAddressComma" />
                                }
                            </ChildContent>

                            <ErrorContent Context="ex">
                                <div class="alert alert-danger">
                                    <strong>Documents tab crashed.</strong><br />
                                    @ex.Message

                                    <div class="mt-2">
                                        <TelerikButton OnClick="@RecoverDocumentsTab">Recover</TelerikButton>
                                    </div>
                                </div>
                            </ErrorContent>
                        </ErrorBoundary>
                    </Content>
                </TabStripTab>
            }
         </TelerikTabStrip>
    </FormBody>
</EditPage>

@code{
    [Parameter]
    public string? SerializedDataObjectReference { get; set; }
    [Parameter] public string? ModalId { get; set; }
    [Parameter]
    public EventCallback<DataObjectReference> ParentDataObjectReferenceChanged { get; set; }
    [Parameter]
    public EventCallback<Exception> OnError { get; set; }
    [Parameter] public bool IsDetailWindowed { get; set; } = false;
    [Parameter] public bool IsMainRecordContext { get; set; } = true;
    [Parameter]
    public Dictionary<string, Any> TransientVirtualProperties { get; set; } = new();

    private API.Client.FormHelper? _formHelper;
    private ErrorBoundary? _docsBoundary;

    private bool ShowDocumentsTab =>
        Config.Value.Environment.ShowDocumentsTab;

    private void RecoverDocumentsTab()
    {
        _docsBoundary?.Recover();
        StateHasChanged();
    }

    private void EnsureFormHelper()
    {
        if (_formHelper != null) return;

        _formHelper = new API.Client.FormHelper(
            coreClient,
            sageIntegrationService,
            PWAFunctions.ParseAndReturnEmptyGuidIfInvalid(EntityTypeGuid).ToString(),
            userService);
    }
    protected override async Task OnParametersSetAsync()
    {
        try
        {
            if (ParentDataObjectReference != null)
            {
                ParentDataObjectReference =
                    JsonConvert.DeserializeObject<DataObjectReference>(
                        HttpUtility.UrlDecode(SerializedDataObjectReference) ?? string.Empty);

                await ParentDataObjectReferenceChanged.InvokeAsync(ParentDataObjectReference);
            }

            // Ensure FormHelper exists early so Documents tab can work immediately
            EnsureFormHelper();

            await base.OnParametersSetAsync();
        }
        catch (Exception ex)
        {
            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Error);
            ex.Data.Add("Message", "An error occurred while setting parameters on Quote Detail");
            ex.Data.Add("PageMethod", "QuoteDetail/OnParametersSetAsync()");
            _ = OnError.InvokeAsync(ex);
        }
    }
}