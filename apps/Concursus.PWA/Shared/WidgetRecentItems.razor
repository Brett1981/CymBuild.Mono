<div class="card shadow-sm p-2 m-2" style="max-height:auto">
    <div class="card-body">
        <div class="card-title d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Recent </h5>

        </div>
        <!-- Telerik Grid -->
        <TelerikGrid Data="@_recentItems?.RecentItems" PageSize="10" Class="custom-telerik-grid" SelectionMode="GridSelectionMode.Single" OnRowDoubleClick="HandleRowDoubleClick">
            <GridColumns>
                <GridColumn Field="@nameof(RecentItem.EntityTypeLabel)" Title="Type" />
                <GridColumn Field="@nameof(RecentItem.Label)" Title="Record" />
            </GridColumns>
        </TelerikGrid>
    </div>
</div>

@code {




    [Parameter] public DataObjectReference ParentDataObjectReference { get; set; } = new("", "");

