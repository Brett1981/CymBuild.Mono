@inject IJSRuntime JS

@code {
    [Parameter]
    public EventCallback<string> OnTypeSelected { get; set; }
    [Parameter]
    public EventCallback CloseWindow { get; set; }

   


    private void SelectType(string type)
    {
        OnTypeSelected.InvokeAsync(type); //Make the modal disappear.
    }

    private void CloseModal()
    {
        CloseWindow.InvokeAsync();
    }

}

<div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title">Select Output Type</h5>
                <button type="button" class="btn-close" @onclick="() => CloseModal()" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex justify-content-around">
                    <button class="btn btn-icon btn-blue" @onclick='() => SelectType("Word")'>
                        <i class="bi bi-file-earmark-word"></i>
                        <span>Word</span>
                    </button>
                    <button class="btn btn-icon btn-red" @onclick='() => SelectType("PDF")'>
                        <i class="bi bi-file-earmark-pdf"></i>
                        <span>PDF</span>
                    </button>
                    <button class="btn btn-icon btn-green" @onclick='() => SelectType("Excel")'>
                        <i class="bi bi-file-earmark-excel"></i>
                        <span>Excel</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .modal {
        background-color: rgba(0, 0, 0, 0.5);
    }

    .modal-dialog {
        max-width: 400px;
    }

    .modal-content {
        border-radius: 10px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }

    .modal-header {
        border-bottom: none;
        padding-bottom: 0;
    }

    .modal-body {
        padding: 20px;
    }

    .btn-icon {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 15px;
        font-size: 16px;
        font-weight: 500;
        color: #fff;
        border-radius: 10px;
        width: 100px;
        height: 100px;
        margin: 10px;
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .btn-icon i {
            font-size: 30px;
            margin-bottom: 10px;
        }

        .btn-icon:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

    .btn-blue {
        background-color: #007bff;
        border-color: #007bff;
    }

    .btn-red {
        background-color: #dc3545;
        border-color: #dc3545;
    }

    .btn-green {
        background-color: #28a745;
        border-color: #28a745;
    }
</style>
