<TelerikNotification @ref="@SaveNotification" Class="MyTelerikNotification" HorizontalPosition="NotificationHorizontalPosition.Center" VerticalPosition="NotificationVerticalPosition.Top"></TelerikNotification>
<MessageDisplay @ref="_messageDisplay" ErrorMessage="@ErrorMessage" PageMethod="@PageMethod" MessageType="MessageType" />
<NavigationLock OnBeforeInternalNavigation=this.OnNavigation />

<TelerikMediaQuery Media="@MediaQuery" OnChange="@((doesMatch) => AdaptToScreenSize(doesMatch))"/>

<div class="@DialogCss" tabindex="-1" z-index="10">
    <!-- OE - Fix for CBLD-140-->
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Exit Page</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" @onclick=this.Cancel></button>
            </div>
            <div class="modal-body">
                <p>Changes have been made, Are you sure you want to exit without saving?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" @onclick=this.Navigate>Yes</button>
                <button type="button" class="btn btn-primary" @onclick=this.Cancel>Cancel</button>
            </div>
        </div>
    </div>
</div>


@*  Loading screen while we get the data *@
@if (isLoading)
{
    <div class="d-flex flex-column justify-content-center align-items-center vh-100">

        <TelerikLoader
        Visible    = "@isLoading"
        Size        = "@ThemeConstants.Loader.Size.Large"
        ThemeColor  = "@ThemeConstants.Loader.ThemeColor.Tertiary"
        Type        = "@LoaderType.ConvergingSpinner" />

        <h1 class="mt-2">Loading...</h1>
    </div>
}
else
{
    <!--
    ======================================
    ==             MENU BAR             ==
    ======================================
    -->
    @* Buttons for selecting widgets *@
    <div class="WidgetContainer d-flex flex-column">

        @if(!IsEditMode)
        {
            <!--Edit mode-->
            <div class="d-flex flex-row justify-content-end mb-3">
                <TelerikButton  OnClick="@ToggleEditMode" Class="btn-secondary editButton"> Edit </TelerikButton>
            </div>
        }



        @if (IsEditMode)
        {
            <div class="WidgetOptions @(isSmallScreen ? (MobileFlexColumn +  " mb-5 mt-3" ) : DesktopFlexRow)">
                <!--Adding Widgets-->
                <div class="@(isSmallScreen ? MobileFlexColumn : DesktopFlexRow)">

                    @* <TelerikButton Class="mx-1" OnClick="@AddWorkSpace">Add Workspace</TelerikButton> *@

                    @foreach (var widgetType in WidgetTypes)
                    {
                        <TelerikDropDownButton @ref="@DropDownButton" class="DropDownButton mx-1" Icon="@SvgIcon.Plus" ShowArrowButton="false" >
                            <DropDownButtonContent>Add @(@widgetType == "GA" ? "Gauge" : "Grid")</DropDownButtonContent>
                            <DropDownButtonItems>

                                @foreach (var item in Data.Where(m => m.WidgetType == widgetType))
                                {
                                    bool enabled = true;

                                    if (DashboardWidgets.Where(x => x.Title == item.Text).FirstOrDefault() != null)
                                    {
                                        enabled = false;
                                    }

                                    <DropDownButtonItem Enabled="@enabled" OnClick="@(() => AddWidget(item))">@item.Text</DropDownButtonItem>
                                }

                            </DropDownButtonItems>
                        </TelerikDropDownButton>
                    }
                </div>


                <!--Settings-->
                <div class="d-flex flex-row @(isSmallScreen ? "hideZoomLevelButtons" : "")">
                    <!--Incrementing Size-->
                    <TelerikButtonGroup SelectionMode="@ButtonGroupSelectionMode.Single">

                        <TelerikTooltip TargetSelector=".decreaseWidget" />
                        <ButtonGroupButton class="mr-1 decreaseWidget"  Title="Decrease Widgets Size"  OnClick="@( () => ChangeWidgetAreaSize(-1) )">
                            <i class="bi bi-dash-circle-fill fs-5"></i>
                        </ButtonGroupButton>

                        <TelerikTooltip TargetSelector=".increaseWidget" />
                        <ButtonGroupButton class="increaseWidget" Title="Increase Widgets Size"  OnClick="@( () => ChangeWidgetAreaSize(1) )">
                            <i class="bi bi-plus-circle-fill fs-5"></i>
                        </ButtonGroupButton>
                    </TelerikButtonGroup>

                </div>

                <!-- Save Button -->
                <div class="@(isSmallScreen ? (MobileXGap + " flex-column mt-5") : "d-flex flex-row")">
                    <button class="btn btn-success @(isSmallScreen ? "mb-3" : "mx-2")" type="button" @onclick="@(() => this.SaveStateToDB())">
                        <i class="bi bi-save-fill"></i> Save
                    </button>
                    <button class="btn btn-warning" type="button" @onclick="@(() => this.CancelEditMode())">
                        <i class="bi bi-x-square"></i> Cancel
                    </button>
                </div>
            </div>
        }


        <!--
        ======================================
        ==           WIDGET AREA            ==
        ======================================
        -->
        <div class="WidgetArea">

            @if(BoardIsEmpty)
            {
                <div class="emptyBoard d-flex flex-column justify-content-center text-center" style="background-color: #ffffff">
                    <i class="bi bi-folder" style="font-size: 60px; color: lightblue;"></i>
                    <h1 style="font-size: 40px; color: lightblue;">Start a new dashboard by clicking "Edit".</h1>
                </div>
            }

            <TelerikTileLayout @ref="@Dashboard"
            Height="100%"
            Columns="@(isSmallScreen ? 1 : NumberOfColumns)"
            RowHeight="@(RowHeight + "px")"
            ColumnWidth="@(isSmallScreen ? "150px" : ColumnWidth + "px")"
            Resizable="@IsEditMode"
            Reorderable="@IsEditMode"
            Class="@(mobileTileLayout + " " + (BoardIsEmpty ? "hideBoard" : ""))">

                <TileLayoutItems>

                    @foreach (var Widget in DashboardWidgets)
                    {

                        //Create an CSS ID for each widget - we will target this to colour the <HeaderTemplate>
                        //This is needed since we cannot assign an ID to the header template.
                        var widgetHeaderID = System.Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(Widget.Id));

                        <TileLayoutItem
                        Class="@(IsWidgetFullScreen(Widget) + " " + MobileScreenClass + " tileBorder")"
                        HeaderText=""
                        RowSpan="@Widget.RowSpan"
                        ColSpan="@Widget.ColSpan"
                        Id="@(Widget.Id)">
                            <HeaderTemplate>
                                <div class="d-flex flex-row justify-content-between mb-2" id="@widgetHeaderID" style="background-color: @(Widget.Color)">
                                    <strong style="color: #000000">@Widget.Title</strong>

                                    <div class="WidgetButtons ed-flex flex-row">

                                        @if(!IsEditMode)
                                        {
                                            var MyInvoicingId = "41291bdc-7fac-47f0-8517-e2afe51e9ec3";

                                            @if( Widget.Id == MyInvoicingId)
                                            {
                                                <TelerikTooltip TargetSelector=".tooltip-target">
                                                    <Template>

                                                        <div>
                                                            <ul>
                                                                <li>Grey arrow: Total amount after combining the gross amount of all the invoices generated by the user for the previous month (calculated as gross/1000).</li>
                                                                <li>Blue arrow: Total amount after combining the gross of all the invoices generated by the user for the current month (calculated as gross/1000).</li>
                                                                <li>Green bar: Currently, this bar has no specific function.</li>
                                                            </ul>
                                                        </div>

                                                    </Template>
                                                </TelerikTooltip>

                                                
                                            }
                                            <btn class="btn btn-default"   @onclick="() => ToggleFullScreen(Widget)" disabled="@isFullScreen" >
                                                <i class="bi bi-arrows-angle-expand" />
                                            </btn>
                                        }
                                        else
                                        {
                                            <div class="d-flex flex-row justify-content-between">
                                                <button class="btn btn-danger float-right" title="Delete Widget" onclick="@(() => RemoveWidget(Widget.Title, Widget.WidgetType))">
                                                    <i class="bi bi-trash" style="color: @(Widget.Color == "#f8f9fa" ? "#000000" : "#ffffff")" />
                                                </button>
                                                <TelerikColorPicker ValueFormat="ColorFormat.Hex" @bind-Value="@Widget.Color" OnChange="(color) => SetWidgetColor(Widget, widgetHeaderID, color)">
                                                    <ColorPickerViews>
                                                        <ColorPickerPaletteView Colors="ColorPalettePresets.Basic"/>
                                                    </ColorPickerViews>
                                                </TelerikColorPicker>

                                            </div>
                                        }

                                    </div>
                                </div>
                            </HeaderTemplate>

                            <!-- Widget Content.-->
                            <Content>
                                <div class="d-flex flex-column h-100">
                                    <div class="d-flex flex-column justify-content-start" style="flex-grow: 1; overflow: auto; ">
                                        @Widget.Content
                                    </div>
                                </div>
                            </Content>
                        </TileLayoutItem>

                        @*Set the colour of the outer header.*@
                        if(Widget.Color != null){
                            SetWidgetColor(Widget, widgetHeaderID, Widget.Color);
                        }
                    }

                </TileLayoutItems>
            </TelerikTileLayout>


        </div>
    </div>
}

<script>

    /*
    Applies colour to the widget header itself.
    */
    window.applyColourToWidgetHeader = (ID, Colour) => {

    console.log("Setting header colour!");
    try
    {
    var header = document.getElementById(ID);

    if(header && Colour)
    {
    header.parentElement.style.backgroundColor = Colour;
    console.log("Colour has been set for widget header. [ Colour: " + Colour + " ]");

