    //Serves as feedback from the DB - success/failure
    private void ShowDatabaseSaveNotification(bool IsSavedInDB, string Message = "")
    {

        string SuccessText          = (IsSavedInDB && Message == "") ? "Dashboard layout has been succesfully saved." : Message;
        string Color                =  IsSavedInDB  ? ThemeConstants.Notification.ThemeColor.Success : ThemeConstants.Notification.ThemeColor.Error;


        SaveNotification.Show(new NotificationModel()
        {
            Text = (Message != "") ? Message : SuccessText,
            ThemeColor = Color,
            Closable = true,
