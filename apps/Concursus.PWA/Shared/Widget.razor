    /*
    * Here, we load the options into the buttons while we are waiting
    * for the page to load.
    */
    protected override async Task<Task> OnInitializedAsync()
    {
        try
        {
            GetUserId();

            //string Layout = await LoadDashBoardLayout();
            boardConfigFromDB = System.Text.Json.JsonSerializer.Deserialize<SavedTileState>(await LoadDashboardLayout());

            //Apply colouring to the "My Work" area - if there are any.
            if (boardConfigFromDB.MyWorkCSS != null)
            {
                MyWorkCSS = boardConfigFromDB.MyWorkCSS; //Must be populated to ensure it does not get lost on save.
                MyWorkCSSAsJSON = System.Text.Json.JsonSerializer.Serialize(MyWorkCSS);
            }

          
            AddWidgetsFromConfig();

            await Task.Delay(100);

            isLoading = false;
        }
        catch (Exception ex)
        {
            HandleRenderHandleError(ex);

            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Error);
            ex.Data.Add("AdditionalInfo", "Error loading the dashboard.");
            ex.Data.Add("PageMethod", "Dashboard/OnInitializedAsync()");
            OnError(ex);
        }

        return base.OnInitializedAsync();
    }


    private string IsWidgetFullScreen(DashBoardWidget tileItem)
    {
        return tileItem.IsFullScreen ? "widget fullscreen tileBorder" : "widget tileBorder";
    }


    async void ToggleFullScreen(DashBoardWidget tile)
    {
        try
        {

            bool ToHandleGagueShrink = (tile.WidgetType == "GA" && tile.IsFullScreen);
            bool ToHandleGaugeExpand = (tile.WidgetType == "GA" && !tile.IsFullScreen);


            //Expanding the widget.
            if(ToHandleGaugeExpand)
            {

                isFullScreen = true;

                string GridGuid = tile.Id;

                if(GridGuid != "")
                {
                    var GridCode = ButtonItems.Where(x => x.Id == tile.Id).FirstOrDefault().GridCode;
                    var GridViewDef = ButtonItems.Where(y => y.Id == tile.Id).FirstOrDefault().GridViewCode;

                    var gridDefinitionListReply = await CoreClient.GridDefinitionListAsync(new GridDefinitionListRequest()
                        {
                            Code  = GridCode,
                            ForUi = true
                        });

                    var gd = gridDefinitionListReply.Grids[0];
                    var gvd = gd.Views.Where(view => view.Code == GridViewDef).FirstOrDefault();

                    tile.IsFullScreen = true;
                    tile.Content =@<DynamicGridView GridCode="@GridCode" FullGrid="true"  ViewDefinition="@gvd"/>;

                }
            }
            else if(ToHandleGagueShrink)
            {
                isFullScreen = false;

                var Gauge = ButtonItems.Where(x => x.Id == tile.Id).FirstOrDefault();

                var MetricType = Gauge.MetricType;
                var Metric = Gauge.Metric;


                if (MetricType == "NumberValue")
                    tile.Content = @<NumberValue Metric="@Metric" />;
                else if (MetricType == "ArcGauge")
                    tile.Content = @<ArcGauge Metric="@Metric" />;
                else
                    tile.Content =@<RadialGauge Metric="@Metric" />;

                tile.IsFullScreen = false;
            }
            else
            {
                tile.IsFullScreen = !tile.IsFullScreen;
            }

            StateHasChanged();
        }
        catch(Exception ex)
        {
            HandleRenderHandleError(ex);
            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Error);
            ex.Data.Add("AdditionalInfo", "Error toggling full screen.");
            ex.Data.Add("PageMethod", "Dashboard/ToggleFullScreen()");
            OnError(ex);
        }

    }


    string GetWidgetClass()
    {
        return isFullScreen ? "widget fullscreen" : "widget";
    }


    private void ResetDashboard()
    {
        DashboardWidgets.Clear();
        AddWidgetsFromConfig();
    }


    /*
    * This function returns three things:
    *      [1] The saved board configuration for the user - if there is one.
    *      [2] Grid definitions that can be used as widgets.
    *      [3] Gauge definitions that can be used as widgets.
    *
    * If no board definition is present in the database, it will return a default (empty) configuration.
    *
    * TODO:Probably would be a good idea to seperate the two mechanism into their own functions.
    */
    private async Task<string> LoadDashboardLayout()
    {
        try
        {
            string emptyLayout = "{\"ItemStates\": []}";
            string layoutToLoad = "";

            var userBoardConfiguration = await CoreClient.WidgetLayoutGetAsync(new WidgetLayoutGetRequest()) ?? null;


            if(userBoardConfiguration != null)
            {

                //Extract the grid & gauge definitions -> We will add these to the buttons which the user can pick widgets from.
                var GridViewDefinitions  = userBoardConfiguration.GridViewDefinitions;
                var _Metrics             = userBoardConfiguration.DashboardMetrics;

                //Assign the layout we will display.
                layoutToLoad             = userBoardConfiguration.WidgetLayout ?? emptyLayout;

                //Now, we populate the buttons, starting with the grids.
                foreach(var grid in GridViewDefinitions)
                    Data.Add(new ButtonSelection {
                        Id = grid.Guid,
                        Text = grid.Name,
                        WidgetType = "GR",
                        GridCode = grid.GridViewCode,
                        GridViewCode = grid.Code

                    });


                //Seperately, add the "Recent" + "Scheduled" grids
                Data.Add(new ButtonSelection
                        {
                            Text = "Recent",
                            WidgetType = "GR",
                            Id = "RECENT",
                        });

                Data.Add(new ButtonSelection
                        {
                            Text = "Scheduled",
                            WidgetType = "GR",
                            Id = "SCHEDULE"
                        });
                // Check if AI error service is enabled Add "Jira Tickets" button if it is enabled.
                if (Config.GetValue<bool>("AiErrorService:Enabled"))
                {
                    Data.Add(new ButtonSelection
                        {
                            Text = "Jira Tickets",
                            WidgetType = "GR",
                            Id = "JIRATICKETS"
                        });
                }

                //Next, populate the button for the gauges.
                foreach(var metric in _Metrics)
                {
                    DashboardMetric DashBoardM = new DashboardMetric()
                    {
                        Label               = metric.Label,
                        DisplayOrder        = metric.DisplayOrder,
                        DisplayGroupName    = metric.DisplayGroupName,
                        Min                 = metric.Min,
                        Max                 = metric.Max,
                        MinorUnit           = metric.MinorUnit,
                        MajorUnit           = metric.MajorUnit,
                        StartAngle          = metric.StartAngle,
                        EndAngle            = metric.EndAngle,
                        Reverse             = metric.Reverse,
                        MetricTypeName      = metric.MetricTypeName,
                        MetricSqlQuery      = metric.MetricSqlQuery,
                        PageUri             = metric.PageUri,
                        Guid                = metric.Guid,
                    };

                    //Add the ranges & values to the gauges.
                    foreach(var range in metric.Ranges)
                    {
                        DashBoardM.Ranges.Add(range);
                    }

                    foreach(var value in metric.Values)
                    {
                        DashBoardM.Values.Add(value);
                    }

                    Data.Add(new ButtonSelection {
                        Text = metric.Label,
                        MetricType = metric.MetricTypeName,
                        WidgetType = "GA",
                        Id = metric.Guid,
                        Metric = DashBoardM,
                        GridCode = metric.Code,
                        GridViewCode = metric.GridViewCode
                    });

                }
            }

            //Assign the populated data to the buttons.
            ButtonItems = Data;

            //Finally, return the layout which we will load.
            return layoutToLoad;

        }
        catch(Exception ex)
        {
            HandleRenderHandleError(ex);

            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Error);
            ex.Data.Add("AdditionalInfo", "Error loading the dashboard layout.");
            ex.Data.Add("PageMethod", "Dashboard/LoadDashBoardLayout()");
            OnError(ex);

            //Return empty configuration on exception.
            return "{\"ItemStates\": []}";
        }

    }


    private async void ChangeWidgetAreaSize(int val)
    {

        if (!DashboardWidgets.Any())
            return;

        foreach(var item in DashboardWidgets)
        {
            var NewColSize = (item.ColSpan + val);

            //Grids - no smaller than 3 cols
            if(item.WidgetType == "GR")
            {
                if (NewColSize >= 3 && NewColSize <= 10)
                {
                    item.ColSpan = NewColSize;
                    GridColSpan = NewColSize;
                }

            }
            //Gauges
            else
            {
                if (NewColSize >= 2 && NewColSize <= 3)
                {
                    item.ColSpan = NewColSize;
                    GaugeColSpan = NewColSize;
                }
            }
        }
        StateHasChanged();
    }

    /*
    * Removes widget from the board.
    */
    private async void RemoveWidget(string title, string type)
    {
        try
        {
            bool isConfirmed = await Dialogs.ConfirmAsync($"Are you sure you would like to delete the \"{title}\" widget?", "Delete Widget");

            if (isConfirmed)
            {
                var WidgetToDelete = DashboardWidgets.Where(m => m.Title == title && m.WidgetType == type).FirstOrDefault();

                DashboardWidgets.Remove(WidgetToDelete);
                HasChanges = true;

                //Show "Board is empty" message if the user has deleted the last item.
                if (!DashboardWidgets.Any())
                {
                    BoardIsEmpty = true;
                }

                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            HandleRenderHandleError(ex);

            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Warning);
            ex.Data.Add("AdditionalInfo", "Error deleting the widget.");
            ex.Data.Add("PageMethod", "RemoveWidget()");
            OnError(ex);
        }
    }

    /*
    * Main function for adding widgets to the board.
    */
    private async void AddWidget(ButtonSelection item)
    {
        try
        {
            //Reset, otherwise the widget will not show.
            if (BoardIsEmpty)
                BoardIsEmpty = false;

            DashBoardWidget Widget = new DashBoardWidget();

            switch (item.WidgetType)
            {

                //Gauge
                case "GA":
                    Widget = await AddGaugeToBoard(item);
                    break;

                //Grid
                case "GR":

                    Widget = await AddGridToBoard(item);
                    await JS.InvokeVoidAsync("adjustColumnWidths");

                    break;
            }

            DashboardWidgets.Add(Widget);

            if(IsEditMode)
                HasChanges = true;

            //await Task.Delay(300); //Task.Delay seems to ensure that the tile state is always correct before we try to get it.

            StateHasChanged();

        }
        catch (Exception ex)
        {
            HandleRenderHandleError(ex);

            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Warning);
            ex.Data.Add("AdditionalInfo", "Error adding the widget to the dashboard.");
            ex.Data.Add("PageMethod", "AddWidget()");
            OnError(ex);
        }
    }

    private async Task<DashBoardWidget> AddGridToBoard(ButtonSelection item)
    {



        var widget = boardConfigFromDB.ItemStates?.FirstOrDefault(x => item.Id == x.Id);

        DashBoardWidget Widget = new DashBoardWidget();
        var WidgetName = item.Text;

        string Title    = item.Text;
        string Type     = item.WidgetType;
        string ID       = item.Id;
        string Color = boardConfigFromDB.ItemStates?.FirstOrDefault(x => item.Id == x.Id)?.Color ?? "#f8f9fa";

        //Default width + height.
        var colSpan = GridColSpan;
        var RowSpan = GridRowSpan;

        //If the widget is present in the config, apply the saved values.
        if(widget != null)
        {
            colSpan = widget.ColSpan;
            RowSpan = widget.RowSpan;
        }

        switch(WidgetName)
        {

            case "My Invoicing":

                var MyInvocingGridDefinitionListReply = await CoreClient.GridDefinitionListAsync(new GridDefinitionListRequest()
                {
                    Code = "FINANCE",
                    ForUi = true
                });

                var MyInvocing = MyInvocingGridDefinitionListReply.Grids[0];
                var MyInvoicingGvd = MyInvocing.Views.Where(v => v.Code == "MYINVOICING").FirstOrDefault();

                Widget = new()
                {
                    Content =  @<DynamicTreeListGridView FullGrid="true" GridCode="FINANCE" ViewDefinition="@MyInvoicingGvd" />,
                    Title = Title,
                    ColSpan = colSpan,
                    RowSpan = RowSpan,
                    WidgetType = Type,
                    Id = ID,
                    Color = Color
                };
                break;

            case "Team Invoicing":

                var TeamInvocinggridDefinitionListReply = await CoreClient.GridDefinitionListAsync(new GridDefinitionListRequest()
                {
                    Code = "FINANCE",
                    ForUi = true
                });

                var TeamInvocing = TeamInvocinggridDefinitionListReply.Grids[0];
                var TeamInvoicingGvd = TeamInvocing.Views.Where(v => v.Code == "TEAMSINVOICING").FirstOrDefault();

                Widget = new()
                {
                    Content =  @<DynamicTreeListGridView @key="@($"Tree-{TeamInvoicingGvd?.Code}-{Guid.NewGuid()}")" FullGrid="true" GridCode="FINANCE" ViewDefinition="@TeamInvoicingGvd" />,
                    Title = Title,
                    ColSpan = colSpan,
                    RowSpan = RowSpan,
                    WidgetType = Type,
                    Id = ID,
                    Color = Color
                };
                break;

            case "Recent":
                Widget = new()
                {
                    Content     = @<WidgetRecentItems />,
                    Title       = Title,
                    ColSpan     = colSpan,
                    RowSpan     = RowSpan,
                    WidgetType  = Type,
                    Id          = ID,
                    Color       = Color
                };
                break;

            case "Scheduled":
                Widget = new()
                {
                    Content     = @<WidgetScheduledItems />,
                    Title = Title,
                    ColSpan = colSpan,
                    RowSpan = RowSpan,
                    WidgetType = Type,
                    Id = ID,
                    Color = Color
                };
                break;

            case "Jira Tickets":
                Widget = new()
                        {
                    Content = @<JiraTickets />,
                    Title = Title,
                    ColSpan = colSpan,
                    RowSpan = RowSpan,
                    WidgetType = Type,
                    Id = ID,
                    Color = Color
                };
                break;

            case "My CDM Work":

                RenderFragment Content;
                int WidgetRowSpan;

                var MyWorkgridDefinitionListReply = await CoreClient.GridDefinitionListAsync(new GridDefinitionListRequest()
                    {
                        Code = "MYWORKV2",
                        ForUi = true
                  });

                var MyWorkGd         = MyWorkgridDefinitionListReply.Grids[0];
                var MyWorkGvd        = MyWorkGd.Views.Where(v => v.Code == "MYCDMPROJECTSV2").FirstOrDefault();
                var orderedMyWorkGvd = MyWorkGvd.Columns.Where(x => !x.IsHidden).OrderBy(c => c.ColumnOrder).ToList();


                //Extract top level headers.
                List<string> TopColumnHeaders = new();
                foreach (var col in orderedMyWorkGvd)
                {
                    //Handle where there is no category
                    // if (col.TopHeaderCategory == " " && TopColumnHeaders.Contains(" "))
                    //     TopColumnHeaders.Add(" ");

                    if (!TopColumnHeaders.Contains(col.TopHeaderCategory))
                        TopColumnHeaders.Add(col.TopHeaderCategory);
                }

                Content =@<MultiColumnDynamicGridView
                            @key="@($"Tree-{MyWorkGd.Code}-{Guid.NewGuid()}")"
                            GridCode="@item.GridCode"
                            CSSFromDB="@MyWorkCSSAsJSON"
                            MyWorkFiltersFromDB="@MyWorkFiltersAsJSON"
                            TopColumnHeaders="@TopColumnHeaders"
                            SendFilterAndSortCallback="@((fs) => GetGridSettingsFromMyWork(fs))"
                            SendJSONToWidgetCallback="@((val) => {GetCSSForMyWork(val);})"
                            FullGrid="true"
                            ViewDefinition="@MyWorkGvd"/>;

                //Should always be the max for "My Work" since it's a wide grid view.
                WidgetRowSpan = GridRowSpan;

                Widget = new()
                {
                    Content = Content,
                    Title = MyWorkGvd.Name,
                    ColSpan = colSpan,
                    RowSpan = RowSpan,
                    WidgetType = item.WidgetType,
                    Id = MyWorkGvd.Guid,
                    Color = Color
                };


                break;

            default:

                var gridDefinitionListReply = await CoreClient.GridDefinitionListAsync(new GridDefinitionListRequest()
                    {
                        Code = item.GridCode,
                        ForUi = true
                    });

                var gd = gridDefinitionListReply.Grids[0];
                var gvd = gd.Views.Where(v => v.Code == item.GridViewCode).FirstOrDefault();


                if (Widget is not null)
                {

                    Content =@<DynamicGridView GridCode="@item.GridCode" FullGrid="true" ViewDefinition="@gvd" @key="@($"Tree-{gvd.Code}-{Guid.NewGuid()}")" />;
                    WidgetRowSpan = GridRowSpan;


                    Widget = new()
                    {
                            Content = Content,
                            Title = gvd.Name,
                            ColSpan = colSpan,
                            RowSpan = RowSpan,
                            WidgetType = item.WidgetType,
                            Id = gvd.Guid,
                            Color = Color
                        };
                }
                else
                {
                    throw new Exception($"Widget {Widget.Title} could not be added. ");
                }

                break;
        }

        return Widget;
    }

    private async Task<DashBoardWidget> AddGaugeToBoard(ButtonSelection item)
    {
        DashBoardWidget Widget = new DashBoardWidget();

        switch (item.MetricType)
        {
            case "NumberValue":
                Widget.Content = @<NumberValue Metric="@item.Metric" />;
                break;

            case "ArcGauge":
                Widget.Content = @<ArcGauge Metric="@item.Metric" />;
                break;

            default:
                Widget.Content =@<RadialGauge Metric="@item.Metric" />;
                break;

        };

        Widget.Title        = item.Text;
        Widget.ColSpan      = GaugeColSpan;
        Widget.RowSpan      = GaugeRowSpan;
        Widget.WidgetType   = item.WidgetType;
        Widget.Id           = item.Id;
        Widget.navigateTo   = (item.Metric?.PageUri + '/' + ClientFunctions.ParseAndReturnEmptyGuidIfInvalid(item.Metric?.Guid).ToString());
        Widget.Color = boardConfigFromDB.ItemStates?.FirstOrDefault(x => item.Id == x.Id)?.Color ?? "#FFFFFF";


        return Widget;
    }

