    catch(_exception)
    {
    console.log(_exception)
    }
    };
</script>


<style>

    @* [Ensure the height is auto and the content can grow/shrink] *@
    .k-tilelayout.telerik-blazor {
    min-height: 100% !important;
    height: 100% !important;
    }

    .sticky {
    position: static !important;
    }

    @* [Hides the Grid View name (like "All Jobs")] *@
    h5.view-name{
    display: none;
    }

    .WidgetOptions{
    margin-bottom: 10px;
    background-color: white;
    padding: 10px;
    border-radius: 20px;
    }


    .WidgetBoard{
    background-color: white;
    border-radius: 20px;
    }

    .DropDownButton{
    height: 100%;
    }

    .show-dialog {
    display: block;
    }

    .MyTelerikNotification .k-notification-container .k-notification {
    margin-top: 20px;
    width: 600px;
    height: 100px;
    font-size: 1.5em;
    text-align: center;
    align-items: center;
    z-index: 101;
    }

    @* [Controls the coloring of the button.] *@
    .editModeOff{
    background-color: red;
    color: white;
    }

    .editModeOn{
    background-color: green;
    color: white;
    }

    @* [Removes the title from the Gauge - so we do not have it 2x] *@
    .card-title .mb-0{
    display: none;
    }

    .card-title {
    justify-content: center !important;
    }

    .allowNewButtonSection{
    display:none !important;
    }

    .fitGridToMobile{
    max-height: 500px;
    height: 100%;
    overflow: auto;
    }

    .tileBorder{
    border: 1px solid black;
    }

    .hideZoomLevelButtons{
    display: none !important;
    }

    @* [Full-screen toggle styles] *@
    .widget {
    transition: transform 0.3s ease, width 0.3s ease, height 0.3s ease;
    transform-origin: center;
    border: 1px solid #ccc;
    overflow: auto;
    }

    .widget.fullscreen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 9999;
    transform: scale(1.0);
    padding: 20px;
    }

    @* [Exit full-screen button styling] *@
    .exit-fullscreen {
    position: absolute;
    top: 10px;
    right: 10px;
    padding: 5px 10px;
    background-color: #f44336;
    color: white;
    border: none;
    cursor: pointer;
    border-radius: 5px;
    }

    .editButton{
    background-color: #565e64 !important;
    color: #ffffff !important;
    }

    @* [Ensures the tile layout adjusts for full screen toggling] *@
    .fullscreen-tile {
    position: absolute;
    width: 100vw;
    height: 100vh;
    top: 0;
    left: 0;
    z-index: 1000;
    }

    @@media (max-width: 768px){
    .k-table-td{
    max-width: 120px !important;
    width: 100% !important;
    }
    }
    .emptyBoard{
    height: 90vh;
    }

    .hideBoard{
    visibility: hidden;
    }
    .k-tooltip{
    background-color: grey !important;
    }

    @*Adds spacing to the color picker from the left.*@
    .k-colorpicker {
    background-color: #f8f9fa !important;
    margin-left: 5px !important;
    }

</style>


