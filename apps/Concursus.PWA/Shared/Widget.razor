    // ====== [CBLD-611] ======
    // Meant to handle the "The render handle is not yet assigned" error
    //Saves the state (so that the JSON is up to date with the CSS bits) + performs a refresh.
    private void HandleRenderHandleError(Exception ex)
    {

        if (ex.Message.Contains("The render handle is not yet assigned"))
        {
            SaveStateToDB(false);


            _ = Task.Run(async () =>
            {
                SaveNotification.Show(new NotificationModel()
                    {
                        Text = "Page will be refreshed to prevent update related error - please, ensure all your widgets are present on the board after the page has reloaded.",
                        ThemeColor = ThemeConstants.Notification.ThemeColor.Info,
                        Closable = true,
                        CloseAfter = 3000 //Display for 3 seconds.
                    });

                await Task.Delay(3000);
                Navigation.Refresh();
            });

        }
    }



