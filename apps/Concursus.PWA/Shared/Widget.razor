    /*
    * Applies the layout (which is saved by the user to the database).
    */
    private async void AddWidgetsFromConfig()
    {

        try
        {

            //Check if we have any widget to add first.
            if (boardConfigFromDB.ItemStates.Any())
            {
                var oldMyWorkID = "e61688d5-1acb-4551-9482-cc8bad0d0d48";

                BoardIsEmpty = false;

                //Add widgets.
                foreach (var widget in boardConfigFromDB.ItemStates)
                {

                    //Skip old My Work grid.
                    if (widget.Id == oldMyWorkID)
                        continue;

                    var selection = ButtonItems.Where(x => x.Id == widget.Id).FirstOrDefault();


                    if (selection != null)
                        this.AddWidget(selection);
                    else
                        continue; //continue if the widget is not present instead of throwing an error.
                    // throw new Exception("There was an error applying a widget to the dasboard.");
                }

                //Without this, TileLayout.GetState() will not return the current configuration.
                await Task.Delay(500);

                //Next, apply the state to ensure the order in which the widgets are displayed is true to the saved configuration.
                var ActiveWidgets = Dashboard.GetState();
                foreach (var widget in ActiveWidgets.ItemStates)
                {
                    var NewState = boardConfigFromDB.ItemStates.Where(x => x.Id == widget.Id).FirstOrDefault();

                    widget.Order = NewState.Order;
                    widget.ColSpan = NewState.ColSpan;
                    widget.RowSpan = NewState.RowSpan;
                }

                //Lastly, apply the state to ensure they are in the correct order.
                Dashboard.SetState(ActiveWidgets);

                await Task.Delay(100);
                StateHasChanged();

                return;
            }

            //Set flag to true to show the "Board is empty" message.
            BoardIsEmpty = true;

        }
        catch(Exception ex)
        {
            HandleRenderHandleError(ex);

            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Error);
            ex.Data.Add("AdditionalInfo", "Error applying the dashboard layout.");
            ex.Data.Add("PageMethod", "Dashboard/ApplyDashBoardLayout()");
            OnError(ex);
        }

    }

    //Returns the current layout of the board - aka, the widgets present.
    private string GetCurrentDashBoardLayout()
    {
        Task.Delay(500); //Due to the async nature, this ensures we get the latest state.

        try
        {
            DashBoardState = Dashboard.GetState() ?? new TileLayoutState();
            SavedTileState stateToBeSaved = new SavedTileState();

            //Add the color, so that it is saved to the database.
            foreach (var widget in DashBoardState.ItemStates)
            {
                SavedTileState.ItemState newState = new();

                newState.ColSpan = widget.ColSpan;
                newState.RowSpan = widget.RowSpan;
                newState.Id = widget.Id;
                newState.Order = widget.Order;
                newState.Color = DashboardWidgets.Where(x => x.Id == widget.Id).FirstOrDefault().Color;

                stateToBeSaved.ItemStates.Add(newState);
            }

            //Add the CSS for the "My Work" grid.
            if(MyWorkCSS is not null)
            {
                stateToBeSaved.MyWorkCSS = MyWorkCSS;
            }

          
            //string TileStateJSON = System.Text.Json.JsonSerializer.Serialize(Dashboard.GetState() ?? new TileLayoutState());
            string TileStateJSON = System.Text.Json.JsonSerializer.Serialize(stateToBeSaved, new System.Text.Json.JsonSerializerOptions() { WriteIndented = true });

            return TileStateJSON;
        }
        catch(Exception ex)
        {
            HandleRenderHandleError(ex);

            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Error);
            ex.Data.Add("AdditionalInfo", ex.Message);
            ex.Data.Add("PageMethod", "Dashboard/GetCurrentDashBoardState()");
            OnError(ex);
        }

        return "{\"ItemStates\": []}";

    }


    private  void SaveStateToDB(bool showMsg = true)
    {
        try
        {
            //Ensure formhelper is instantiated.
            if(_formHelper == null)
                _formHelper = new API.Client.FormHelper(CoreClient, sageIntegrationService, Guid.Empty.ToString(), userService);

            Task.Delay(500);

            if (UserId == -1)
                UserId = UserService?.UserId ?? throw new Exception($"Error saving layout - UserId = {UserId}");


            string TileStateAsJson = this.GetCurrentDashBoardLayout();
            _formHelper.SaveWidgetLayoutToDb(UserId, TileStateAsJson);

            HasChanges = false; //Only after save should the HasChange variable become false.

            if(showMsg){
                ShowDatabaseSaveNotification(showMsg);
                ToggleEditMode();
            }
        }
        catch(Exception ex)
        {
            ex.Data.Add("MessageType", MessageDisplay.ShowMessageType.Error);
            ex.Data.Add("AdditionalInfo", "Error saving the dashboard layout.");
            ex.Data.Add("PageMethod", "Dashboard/SaveStateToDB()");
            OnError(ex);
        }
    }

    private void CancelEditMode()
    {
        IsEditMode = !IsEditMode;

        //If nothing has been added & cancelled, display no item present.
        if (!DashboardWidgets.Any())
            BoardIsEmpty = true;

        HasChanges = false;

        ResetDashboard();
