    //Should also capture the current state of the tile
    private async void ToggleEditMode()
    {

        if (BoardIsEmpty)
        {
            DashBoardStateAsJSON = "{ \"ItemStates\": [] }";
            BoardIsEmpty = false;
        }
        else
        {
            //This is to reset the state if the edit mode is cancelled.
            DashBoardStateAsJSON =  GetCurrentDashBoardLayout();
