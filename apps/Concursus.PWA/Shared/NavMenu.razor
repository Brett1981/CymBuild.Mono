@code {
    private bool _collapseNavMenu = true;
    private bool isTaskListVisible = true;
    private int syncQueueCount { get; set; } = 0;
    private FormHelper? formHelper;
    private HubConnection? hubConnection;
    [CascadingParameter] public string EnvironmentType { get; set; } = "DEV";
    private string? NavMenuCssClass => _collapseNavMenu ? "collapse" : null;

    private async Task OnNavItemClick(string featureName = "")
    {
        if (!string.IsNullOrEmpty(featureName))
        {
            formHelper = new FormHelper(coreClient, sageIntegrationService, Guid.Empty.ToString(), userService);
            Guid userId = ParseAndReturnEmptyGuidIfInvalid(userService.Guid);
            await formHelper.LogUsageAsync(userId, featureName);
        }
        ClientFunctions.ResetStateService(stateService);
        modalService.ResetModalService();
    }

    public static Guid ParseAndReturnEmptyGuidIfInvalid(string inputGuid)
    {
        if (Guid.TryParse(inputGuid, out var parsedGuid))
            return parsedGuid;
        // Return an empty Guid if the inputGuid is not a valid Guid
        return Guid.Empty;
    }
    private void ToggleNavMenu()
    {
        _collapseNavMenu = !_collapseNavMenu;
    }
    private void ToggleTasks()
    {
        isTaskListVisible = !isTaskListVisible;
    }
    protected override async Task OnInitializedAsync()
    {
        await LoadSyncQueueCount();
        await SetupHubConnection();
    }
    private async Task SetupHubConnection()
    {
        if (hubConnection is not null && hubConnection.State == HubConnectionState.Connected)
            return;

        string apiUrl = EnvironmentType switch
        {
            "LIVE" => "https://bre.socotec.co.uk:9601",
            "TEST" => "https://bre.socotec.co.uk:9501",
            "DEV" => "https://bre.socotec.co.uk:9401",
            _ => "https://localhost:5033"
        };

        hubConnection = new HubConnectionBuilder()
            .WithUrl($"{apiUrl}/fileProcessingHub")
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On("SyncQueueUpdated", async () =>
        {
            Console.WriteLine("📡 Received SyncQueueUpdated via SignalR");

            // Update state on the Blazor render context
            await InvokeAsync(async () =>
            {
                await LoadSyncQueueCount();
                NotificationService.ShowInfo($"{syncQueueCount} items pending sync");
                Console.WriteLine($"🔔 syncQueueCount: {syncQueueCount}");
                StateHasChanged(); // this now works correctly
            });
        });

        hubConnection.Reconnecting += error =>
        {
            Console.WriteLine($"Reconnecting to hub: {error?.Message}");
            return Task.CompletedTask;
        };

        hubConnection.Reconnected += id =>
        {
            Console.WriteLine($"Reconnected to hub with ID: {id}");
            return Task.CompletedTask;
        };

        hubConnection.Closed += async error =>
        {
            Console.WriteLine($"Hub connection closed: {error?.Message}");
            await Task.Delay(2000);
            await hubConnection.StartAsync();
        };

        await hubConnection.StartAsync();
        await hubConnection.InvokeAsync("RegisterConnectionId", hubConnection.ConnectionId, userService.Email);
    }
    private async Task LoadSyncQueueCount()
    {
        var items = await SyncService.GetSyncQueueAsync();
        SyncQueueState.SetCount(items?.Count ?? 0);
    }
    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

}