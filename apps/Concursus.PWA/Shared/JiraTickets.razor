@using System.Text.Json
@using Concursus.Components.Shared.Dto
@using Concursus.Components.Shared.Helpers
@using Concursus.Components.Shared.Services
@using System.Text
@using Telerik.Blazor.Components

@inject HttpClient Http
@inject IConfiguration Config
@inject IToastService Toast

<h3>
    <svg width="32" height="32" viewBox="0 0 256 256" style="vertical-align: middle; margin-right: 6px;">
        <path fill="#2684FF" d="M141.12 131.38l-16.72 17.06L92.54 116.6l16.7-17.08z" />
        <path fill="#0052CC" d="M188.57 84.88l-16.7 17.08-39.48-40.26 16.7-17.06z" />
        <path fill="#2684FF" d="M67.38 158.64l16.7-17.08 39.48 40.26-16.7 17.08z" />
    </svg>
    Jira Tickets
</h3>

@if (isLoading)
{
    <TelerikLoaderContainer LoaderType="LoaderType.Pulsing" Text="Refreshing Jira Status'" />
}

<TelerikGrid TItem="AiErrorReportDto"
OnRead="@GridRead"
Pageable="true"
FilterMode="GridFilterMode.FilterRow"
Sortable="true"
PageSize="10">
    <GridColumns>
        <GridColumn Title="Date">
            <Template Context="item">
                @(((AiErrorReportDto)item).CreatedUtc.ToString("g"))
            </Template>
        </GridColumn>

        <GridColumn Field="JiraStatus" Title="Status">
            <Template Context="item">
                @{
                    var status = ((AiErrorReportDto)item).JiraStatus ?? "";
                    var cssClass = "badge-jira-status status-" + status.ToLowerInvariant().Replace(" ", "-").Replace("'", "").Replace(".", "").Replace("/", "-");
                }
                <span class="@cssClass">
                    @(!string.IsNullOrWhiteSpace(status) ? status : "N/A")
                </span>
            </Template>
        </GridColumn>

        <GridColumn Field="JiraTicketKey" Title="Ticket" Filterable="true" />
        <GridColumn Field="ErrorMessage" Title="Title">
            <Template Context="item">
                @{
                    var aiItem = (AiErrorReportDto)item;
                }
                <span title="@aiItem.ErrorMessage">
                    @(aiItem.ErrorMessage?.Length > 50 ? aiItem.ErrorMessage.Substring(0, 50) + "..." : aiItem.ErrorMessage)
                </span>
            </Template>
        </GridColumn>

        <GridColumn Field="JiraPriority" Title="Priority">
            <Template Context="item">
                @{
                    var priority = ((AiErrorReportDto)item).JiraPriority ?? "";
                    var cssClass = "badge-jira-priority " +
                    (priority.StartsWith("P1") ? "priority-p1" :
                    priority.StartsWith("P2") ? "priority-p2" :
                    priority.StartsWith("P3") ? "priority-p3" :
                    priority.StartsWith("P4") ? "priority-p4" :
                    priority.StartsWith("P5") ? "priority-p5" : "priority-p5");
                }
                <span class="@cssClass">@priority</span>
            </Template>
        </GridColumn>

        <GridColumn Title="Actions">
            <Template Context="item">
                @{
                    var aiItem = (AiErrorReportDto)item;
                }
                <TelerikButton OnClick="@(() => ShowDetails(aiItem))">👁 View</TelerikButton>
            </Template>
        </GridColumn>

    </GridColumns>
</TelerikGrid>

<TelerikWindow @bind-Visible="@detailsVisible" Width="700px">
    <WindowTitle>Jira Details</WindowTitle>
    <WindowContent>
        <p><strong>Ticket:</strong></p>
        <pre>@selected?.JiraTicketKey</pre>

        <p><strong>Status:</strong></p>
        @{
            var rawStatus = selected?.JiraStatus?.ToLowerInvariant() ?? "other";
            var normalizedStatus = System.Text.RegularExpressions.Regex.Replace(rawStatus, @"[^a-z0-9\-]", "-");
            var statusClass = $"badge-jira-status status-{normalizedStatus}";

        }
        <span class="@statusClass">@selected?.JiraStatus</span>

        <p class="mt-2"><strong>Priority:</strong></p>
        @{
            var prio = selected?.JiraPriority ?? "";
            var prioClass = prio.StartsWith("P1") ? "priority-p1" :
            prio.StartsWith("P2") ? "priority-p2" :
            prio.StartsWith("P3") ? "priority-p3" :
            prio.StartsWith("P4") ? "priority-p4" :
            prio.StartsWith("P5") ? "priority-p5" : "priority-p5";
        }
        <span class="badge-jira-priority @prioClass">@prio</span>

        <p><strong>Title:</strong></p>
        <textarea class="form-control ai-field" readonly style="height:40px">@selected?.ErrorMessage</textarea>

        <p><strong>Jira Description:</strong></p>
        @if (!string.IsNullOrWhiteSpace(selected?.JiraDescription) && selected.JiraDescription.Trim().StartsWith("{"))
        {
            <div class="jira-description-box">
                @((MarkupString)JiraDescriptionFormatter.ConvertAdfToHtml(selected.JiraDescription))
            </div>
        }
        else
        {
            <p><em>No Jira description available</em></p>
        }



        <div class="text-end mt-3">
            <TelerikButton OnClick="@(() => detailsVisible = false)" ThemeColor="Primary" Class="me-2">Close</TelerikButton>
        </div>
    </WindowContent>
</TelerikWindow>

@code {
    [Parameter] public EventCallback<Exception> OnError { get; set; }

    private List<AiErrorReportDto> errorReports = new();
    private List<AiErrorReportDto> pagedItems = new();
    private bool isLoading = false;
    private bool isInitialLoad = true;
    private bool hasLoadedOnce = false;
    private AiErrorReportDto selected;
    private bool detailsVisible = false;
    private string baseUrl => Config["AiErrorService:BaseUrl"].TrimEnd('/') + "/";
    private int totalCount = 0;
    private GridReadEventArgs? lastGridArgs = null;
    private TelerikGrid<AiErrorReportDto> GridRef { get; set; }


    private async Task GridRead(GridReadEventArgs args)
    {
        try
        {
            isLoading = true;

            var response = await Http.PostAsJsonAsync($"{baseUrl}api/ErrorReport/paged-source", args.Request);

            var result = await response.Content.ReadFromJsonAsync<DataSourceResult<AiErrorReportDto>>();

            args.Data = result?.Data ?? new List<AiErrorReportDto>();
            args.Total = result?.Total ?? 0;

            await RefreshStatusesForVisibleAsync(args.Data.Cast<AiErrorReportDto>().ToList());
        }
        catch (Exception ex)
        {
            Toast.ShowError($"❌ Grid read failed: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }




    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !hasLoadedOnce)
        {
            hasLoadedOnce = true;
            if (GridRef != null)
            {
                await GridRef.SetStateAsync(new GridState<AiErrorReportDto>());
            }
        }
    }

    private async Task RefreshStatusesForVisibleAsync(List<AiErrorReportDto> visibleRows)
    {
        foreach (var row in visibleRows.Where(r => !string.IsNullOrWhiteSpace(r.JiraTicketKey)))
        {
            try
            {
                var result = await Http.GetFromJsonAsync<AiStatusDto>($"{baseUrl}api/ErrorReport/status/{row.JiraTicketKey}");
                if (result != null)
                {
                    row.JiraStatus = result.JiraStatus;
                    row.JiraPriority = result.JiraPriority;
                    row.JiraLastSyncedUtc = result.JiraLastSyncedUtc;
                    row.JiraDescription = result.JiraDescription;
                }

            }
            catch (Exception ex)
            {
                Toast.ShowWarning($"⚠️ Status check failed for {row.JiraTicketKey}: {ex.Message}");
            }
        }

        StateHasChanged();
    }



    private void ShowDetails(AiErrorReportDto report)
    {
        selected = report;
        detailsVisible = true;
    }

    private int ParseJiraKey(string key)
    {
        if (string.IsNullOrWhiteSpace(key)) return 0;
        var parts = key.Split('-');
        return parts.Length == 2 && int.TryParse(parts[1], out var num) ? num : 0;
    }

    public class AiStatusDto
    {
        public string JiraStatus { get; set; } = string.Empty;
        public string JiraPriority { get; set; } = string.Empty;
        public string JiraDescription { get; set; } = string.Empty;
        public DateTime? JiraLastSyncedUtc { get; set; }
    }

    public class AiErrorReportDto
    {
        public string Hash { get; set; } = string.Empty;
        public string UserId { get; set; } = string.Empty;
        public string AiAnalysis { get; set; } = string.Empty;
        public string JiraTicketKey { get; set; } = string.Empty;
        public string JiraUrl { get; set; } = string.Empty;
        public string JiraStatus { get; set; } = string.Empty;
        public string JiraDescription { get; set; } = string.Empty;
        public string JiraPriority { get; set; } = string.Empty;
        public string ErrorMessage { get; set; } = string.Empty;
        public string StackTrace { get; set; } = string.Empty;
        public string ContextJson { get; set; } = string.Empty;
        public DateTime CreatedUtc { get; set; }
        public DateTime? JiraLastSyncedUtc { get; set; }
    }


}

