@using System.Dynamic
@using Concursus.API.Client.Models
@using Concursus.PWA.Classes
@using Telerik.DataSource
@using Telerik.DataSource.Extensions

@inject Core.CoreClient coreClient
@inject NavigationManager NavManager
@inject IJSRuntime JsRuntime
@inject ModalService modalService
@inject RefreshService refreshService
@inject IJSRuntime JSRuntime //CBLD-361
@attribute [Authorize]
@inject IJSRuntime JS

@inject Helpers.LocalStorageAccessor LocalStorageAccessor //CBLD-12


@inherits DynamicGridView

@*  CBLD-106  *@
@inject Helpers.SessionStorageAccessor SessionStorageAccessor //CBLD-12


<MessageDisplay @ref="_messageDisplay" ErrorMessage="@ErrorMessage" PageMethod="@PageMethod" MessageType="MessageType" />
<ErrorBoundary>
    <ChildContent>
        <!--CBLD-408: Added -> allowNewButtonSection so we can hide the button on widgets
        <div class="d-flex flex-wrap justify-content-between">
                    <div class="p-2 ">
                <h5 class="view-name">@ViewDefinition?.Name</h5>
            </div>

            <div class="p-2">
                <div class="button-group">
                    @if(ViewDefinition is not null && ViewDefinition.AllowNew)
                    {
                        <btn class="btn btn-success allowNewButtonSection" id="newBtn" type="button" @onclick="AddNew"><i class="bi bi-plus-circle-fill me-2" style="font-size: 1.2rem;"></i> New</btn>
                    }
                    @* Button for enabling cell colouring. *@
                    @* <btn class="@EditCellsButtonColor" id="newBtn" type="button" @onclick="ToggleEditCells"><i class="bi bi-brush me-2" style="font-size: 1.2rem;"></i> @EditCellsButtonText</btn> *@
                </div>
            </div>

        </div>
        @if (ViewDefinition is not null)
        {
            @if (FullGrid)
            {

              
                <div class="grid-container">
                    <TelerikGrid TItem="ExpandoObject"
                    OnRead="@ReadItems"
                    Pageable="true"
                    Sortable="true"
                    PageSize="50"
                    Height="100%"
                    Width="100%"
                    Resizable="true"
                    OnRowDoubleClick="@OnRowDoubleClickHandler"
                    @ref="@GridRef"
                    FilterMode="@GridFilterMode.FilterMenu"
                    SelectionMode="GridSelectionMode.Single"
                    OnStateInit="@((GridStateEventArgs<ExpandoObject> args) => OnStateInitHandler(args))"
                    ScrollMode="@GridScrollMode.Scrollable"
                    OnStateChanged="@( (GridStateEventArgs<ExpandoObject> args) => OnGridStateChanged(args) )">
                        <GridSettings>
                            <GridPagerSettings InputType="PagerInputType.Input"
                            PageSizes=null
                            ButtonCount="5"
                            Responsive="true"
                            Position="PagerPosition.Bottom">
                            </GridPagerSettings>
                        </GridSettings>
                        <GridColumns>

                            @* Iterate over the top level columns & then assign the low level headers*@
                            @foreach(var topLevelColumn in TopColumnHeaders)
                            {


                                //Add unique ID to each top header to enable colouring.
                                //Empty ( " " ) should not be formatted - format anything else.
                                var topHeaderCSSId = (topLevelColumn != " ") ? (topLevelColumn.Replace(" ", "_") + "_topHeader") : "empty_topHeader";

                                //Remove "&" (if applicable) to prevent causing CSS selector issues.
                                topHeaderCSSId = topHeaderCSSId.Replace("&", ""); 

                                var ToolTipMsg = "Right-click the text to change the header colour";
                                if(!AllHeaders.ContainsKey(topHeaderCSSId))
                                    AllHeaders.Add(topHeaderCSSId, false);

                                <TelerikTooltip TargetSelector="@($".{topHeaderCSSId}")"/>

                                <GridColumn 
                                Resizable="true"
                                Locked=@(topLevelColumn == "Project" ? true : false)
                                Title="@topLevelColumn">
                                    <HeaderTemplate>

                                        <span Title="@(ToolTipMsg)" class="@topHeaderCSSId  @(ShowPaletteForHeader ? "expanded-th" : "")">@topLevelColumn</span>

                                        <TelerikContextMenu
                                        Selector="@($".k-header .{topHeaderCSSId}")"
                                        Data="@MenuItems"
                                        OnClick="@( (ContextMenuItem itm) => ClickHandlerForColouring(itm, topHeaderCSSId))"/>


                                        @{
                                            if (ShowPaletteForHeader && AllHeaders[topHeaderCSSId] == true)
                                            {
                                                <TelerikColorPicker ValueFormat="ColorFormat.Hex" Value="#f8f9fa"  OnChange="@((color) => SetHeaderColour(color, topHeaderCSSId))">
                                                    <ColorPickerViews>
                                                        <ColorPickerPaletteView Colors="ColorPalettePresets.Basic"/>
                                                    </ColorPickerViews>
                                                </TelerikColorPicker>
                                            }
                                        }
                                    </HeaderTemplate>
                                    <Columns>

                                        @*Iterate over the top headers first - order by the topheadercolumnorder field. *@
                                        @foreach (GridViewColumnDefinition? gvcd in ViewDefinition.Columns.Where(o => !o.IsHidden && o.TopHeaderCategory == topLevelColumn).OrderBy(o => o.TopHeaderCategoryOrder))
                                        {

                                            if (!gvcd.IsHidden)
                                            {
                                                <GridColumn
                                                    Field="@gvcd.Name"
                                                    Title="@gvcd.Title"
                                                    FieldType="@(PWAFunctions.DetermineFieldType(gvcd.DisplayFormat))"
                                                    Visible="gvcd.IsHidden != true"
                                                    Filterable="@gvcd.IsFiltered"
                                                    OnCellRender="OnCellRenderHandler"
                                                    Sortable="true"
                                                    Width="125px"
                                                    Resizable="true">

                                                    <Template>

                                                        @{
                                                            //Create uninque ID for each cell.
                                                            var uniqueCSSClassName = EncodeClassNameAsBase64(gvcd, context);
                                                        }
                                                        <div id="@(uniqueCSSClassName)">

                                                            @* @{ *@
                                                            @*     if (EditCellsEnabled) *@
                                                            @*     { *@
                                                            @*         <div class="d-flex flex-row justify-content-end px-2"> *@
                                                            @*             <TelerikColorPicker ValueFormat="ColorFormat.Hex" Value="#FFFFFF"  OnChange="(color) => SetCellColour(color, uniqueCSSClassName, context)"> *@
                                                            @*                 <ColorPickerViews> *@
                                                            @*                     <ColorPickerPaletteView Colors="ColorPalettePresets.Basic"/> *@
                                                            @*                 </ColorPickerViews> *@
                                                            @*             </TelerikColorPicker> *@
                                                            @*         </div> *@
                                                            @*     } *@
                                                            @* } *@

                                                            <div class="custom-ellipsis">
                                                                @(GetColumnTemplate(gvcd.Name)(context))
                                                            </div>
                                                        </div>
                                                    </Template>
                                                </GridColumn>
                                            }
                                        }
                                    </Columns>
                                </GridColumn>
                            }
                        </GridColumns>
                    </TelerikGrid>
                </div>


                <div class="back-to-top-button">
                    <button class="btn btn-secondary" @onclick="ScrollToTop">
                        <i class="bi bi-arrow-up-circle"></i> Back To Top
                    </button>
                </div>
            }

            @if (ViewDefinition.IsDetailWindowed)
            {
                <TelerikWindow @ref="ModalWindow"
                Class="responsive-window"
                Visible="@WindowIsVisible"
                Modal="true"
                CloseOnOverlayClick="false"
                VisibleChanged="@WindowVisibleChangedHandler"
                MaxHeight="100vh">
                    <WindowTitle>@WindowTitle</WindowTitle>
                    <WindowContent>
                        <DynamicComponent Type="@Type.GetType($"Concursus.PWA.Pages.{ViewDefinition.DetailPageUri}")" Parameters="@_detailPageParameters" />
                    </WindowContent>
                    <WindowActions>
                        <WindowAction Name="Minimize"></WindowAction>
                        <WindowAction Name="Maximize"></WindowAction>
                        <WindowAction Name="Close" OnClick="@CloseWindow"></WindowAction>
                    </WindowActions>
                </TelerikWindow>
            }
            @* Modal to display DynamicBatchGridView when initiated from GridButtonMenu *@

        }
    </ChildContent>
    <ErrorContent Context="ex">
        <ErrorDisplay ErrorMessage="@ex.Message"/>
    </ErrorContent>
</ErrorBoundary>

<script>
    //Add event listener to when the page is loaded.
    document.addEventListener("keypress", function (e) {


    // Select the filter button by class
    const filterButton = document.querySelector(".k-button-solid-primary");
    const enterPressed = (e.key === 'Enter');

    if (enterPressed) {
    console.log("Enter has been pressed down!");
    if (filterButton) filterButton.click();
    }

    });
</script>

<script>
         
        window.applyCSSForHeader = (className, colour) => 
        {
            console.log("Applying" + colour  +  "colour for header with class " + className );
            var header = document.getElementsByClassName(className)[0];

            if(header){
                console.log(header);
                header.parentElement.parentElement.parentElement.style.backgroundColor = colour;
            }
        };

        window.applyCSSToGrid = (colours) => 
        {
            colours.forEach((CSS) => {
                console.log("Applying CSS to grid: [Class] " + CSS.className + " [Colour] " + CSS.colour );
                //Check if we are colouring a header based on the class name.
               
                var cell = document.getElementsByClassName(CSS.className)[0];

                if(cell)
                {
                    //Nested 3 levels deep.
                    cell.parentElement.parentElement.parentElement.style.backgroundColor = CSS.colour;
                }
                
            });
        };
</script>



<style>
    .sticky {
        position: sticky;
        z-index: 100; /* Ensure the sticky header is above other elements */
        background-color: white; /* Optional, to prevent content showing through */
    }

        .grid-container .k-grid td {
            min-width: 100%;
            width: 100%;
    }


    .view-name {
        padding: 5px;
    }

    .width-100 {
        width: 100%;
    }

    .grid .k-grid-content tr {
        line-height: 32px;
    }

    .k-grid-content{
        overflow: scroll !important;
    }

    /* Ensure text overflow with ellipsis for grid cells */
    .custom-ellipsis,
    .k-grid td.custom-ellipsis,
    .k-grid tr.custom-ellipsis .k-table-td {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* Container to enable horizontal scrolling */
    .grid-container {
        max-width: 100%; /* Ensure the container does not exceed the viewport width */
        overflow-x: auto; /* Enable horizontal scrolling */
    }

    /* Adjusting the grid layout */
    .grid-container .k-grid {
@* min-width: 1200px; /* Adjust this value based on your columns' total width */ *@
        width: 100%; /* This ensures the grid will take up all available width */
        table-layout: fixed; /* Use fixed layout for the grid */
    }



    /* Style for the back-to-top button */
    .back-to-top-button {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 1000; /* Ensure it is on top of other elements */
        opacity: 0.5; /* Initial opacity set to 50% */
        transition: opacity 0.3s ease; /* Smooth transition for hover effect */
    }

        /* Full opacity on hover for better visibility */
        .back-to-top-button:hover {
            opacity: 1;
        }


    .k-grid .k-grouping-row {
        position: static;
        z-index: auto;
        top: 0;
    }

    .k-grid .k-grouping-row td {
        position: sticky;
        z-index: 2;
        top: inherit;
        bottom: inherit;
        min-width: 100%;
    }

    #newBtn{
        padding: .5rem !important;
    }

    th {
        transition: width 0.3s ease-in-out; /* Smooth transition for width change */
    }

    .expanded-th {
        width: 200px; /* Increase width to fit the color picker */
    }

    .greyed-out-cell{
        background-color: #808080 !important;
    }
    .greyed-out-cell::before{
        content: " ";
    }
</style>
