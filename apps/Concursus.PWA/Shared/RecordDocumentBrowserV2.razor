    private string? GetNavigationWarning(DocumentsNavigationItem item)
    {
        if (item is null || string.IsNullOrWhiteSpace(item.NavigationKey))
            return null;

        return _navigationWarnings.TryGetValue(item.NavigationKey, out var value)
            ? value
            : null;
    }

    private void SetNavigationWarning(DocumentsNavigationItem item, string warning)
    {
        if (item is null || string.IsNullOrWhiteSpace(item.NavigationKey))
            return;

        _navigationWarnings[item.NavigationKey] = warning;
    }

    private void ClearNavigationWarning(DocumentsNavigationItem item)
    {
        if (item is null || string.IsNullOrWhiteSpace(item.NavigationKey))
            return;

        _navigationWarnings.Remove(item.NavigationKey);
    }

    private static string BuildNavigationWarning(Exception ex)
    {
        var message = ex.Message?.Trim();

        if (string.IsNullOrWhiteSpace(message))
        {
            return "This record's document location is currently unavailable.";
        }

        if (message.Contains("resource could not be found", StringComparison.OrdinalIgnoreCase) ||
            message.Contains("not found", StringComparison.OrdinalIgnoreCase))
        {
            return "This record exists, but its SharePoint document location could not be found.";
        }

        return message;
    }

    private static string GetItemIcon(DocumentsListItem item) => item.IsFolder ? "📁" : "📄";

    private static string FormatTimestamp(Timestamp? timestamp)
    {
        if (timestamp is null)
            return string.Empty;

        return timestamp.ToDateTime().ToLocalTime().ToString("dd/MM/yyyy HH:mm");
    }

    private static string FormatBytes(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB", "TB"];
        double value = bytes;
        int unit = 0;

        while (value >= 1024 && unit < units.Length - 1)
        {
            value /= 1024;
            unit++;
        }

        return $"{value:0.##} {units[unit]}";
    }

    private static string GetItemDescription(DocumentsListItem item)
    {
        if (item is null || item.IsFolder)
        {
            return string.Empty;
        }

        var description = item.Description;

        return string.IsNullOrWhiteSpace(description)
            ? string.Empty
            : description.Trim();
    }

