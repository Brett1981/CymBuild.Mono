    private async Task CreateEmailAsync(List<DocumentsListItem> files)
    {
        try
        {
            var selectedFiles = files
                .Where(x => !string.IsNullOrWhiteSpace(x.Id))
                .Select(x => (
                    DriveId: _location?.DriveId ?? string.Empty,
                    ItemId: x.Id,
                    FileName: x.Name ?? string.Empty))
                .Where(x => !string.IsNullOrWhiteSpace(x.DriveId) && !string.IsNullOrWhiteSpace(x.ItemId))
                .ToList();

            if (selectedFiles.Count == 0)
            {
                SetMessage("No valid files were selected.", true);
                return;
            }

            var recordNumber = GetStringValueByPropertyName(EmailRecordNumberPropertyName);
            var recordDescription = GetStringValueByPropertyName(EmailRecordDescriptionPropertyName);
            var recordLocation = GetStringValueByPropertyName(EmailRecordLocationPropertyName);

            var subjectParts = new List<string>();
            if (!string.IsNullOrWhiteSpace(recordNumber))
                subjectParts.Add(recordNumber);
            if (!string.IsNullOrWhiteSpace(recordLocation))
                subjectParts.Add(recordLocation);

            var subject = subjectParts.Count > 0
                ? $"Documents from CymBuild - {string.Join(" - ", subjectParts)}"
                : $"Documents from CymBuild - {_currentFolderName ?? "Documents"}";

            var bodyLines = new List<string>
        {
            "Hi,",
            "",
            "Please find attached the requested document(s) relating to:"
        };

            if (!string.IsNullOrWhiteSpace(recordNumber))
                bodyLines.Add($"Reference: {recordNumber}");

            if (!string.IsNullOrWhiteSpace(recordDescription))
                bodyLines.Add($"Description: {recordDescription}");

            if (!string.IsNullOrWhiteSpace(recordLocation))
                bodyLines.Add($"Location: {recordLocation}");

            bodyLines.Add("");
            bodyLines.Add("If you have any questions, please let us know.");
            bodyLines.Add("");
            bodyLines.Add("Kind regards,");
            bodyLines.Add("SOCOTEC");

            var body = string.Join(Environment.NewLine, bodyLines);

            var result = await FormHelper.DocumentsCreateEmailDraftAsync(
                subject: subject,
                body: body,
                isHtmlBody: false,
                toRecipients: Array.Empty<string>(),
                ccRecipients: Array.Empty<string>(),
                bccRecipients: Array.Empty<string>(),
                attachments: selectedFiles,
                recordGuid: DataObject?.Guid ?? string.Empty,
                entityTypeId: EntityTypeId,
                recordNumber: recordNumber,
                recordDescription: recordDescription,
                recordLocation: recordLocation);

            if (!result.Success || !string.IsNullOrWhiteSpace(result.ErrorReturned))
            {
                SetMessage(
                        string.IsNullOrWhiteSpace(result.ErrorReturned)
                            ? "Unable to create the email draft."
                            : result.ErrorReturned,
                        true);
                return;
            }

            if (string.IsNullOrWhiteSpace(result.WebLink))
            {
                SetMessage("Draft created, but no Outlook draft link was returned.", true);
                return;
            }

            await JS.InvokeVoidAsync("openInNewTab", result.WebLink);
        }
        catch (Exception ex)
        {
            SetMessage(ex.Message, true);
        }
    }
    private string GetStringValueByPropertyName(string propertyName)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(propertyName))
            {
                return string.Empty;
            }

            var entityPropertyGuid = entityProperties?
                .FirstOrDefault(p => string.Equals(p.Name, propertyName, StringComparison.OrdinalIgnoreCase))?
                .Guid;

            if (string.IsNullOrWhiteSpace(entityPropertyGuid))
            {
                return string.Empty;
            }

            var dataProperty = DataObject?.DataProperties?
                .FirstOrDefault(p => p.EntityPropertyGuid == entityPropertyGuid);

            if (dataProperty?.Value == null)
            {
                return string.Empty;
            }

            if (dataProperty.Value.Is(StringValue.Descriptor))
            {
                return dataProperty.Value.Unpack<StringValue>()?.Value ?? string.Empty;
            }

            if (dataProperty.Value.Is(Int32Value.Descriptor))
            {
                return dataProperty.Value.Unpack<Int32Value>().Value.ToString();
            }

            if (dataProperty.Value.Is(Int64Value.Descriptor))
            {
                return dataProperty.Value.Unpack<Int64Value>().Value.ToString();
            }

            if (dataProperty.Value.Is(DoubleValue.Descriptor))
            {
                return dataProperty.Value.Unpack<DoubleValue>().Value.ToString();
            }

            if (dataProperty.Value.Is(FloatValue.Descriptor))
            {
                return dataProperty.Value.Unpack<FloatValue>().Value.ToString();
            }

            if (dataProperty.Value.Is(BoolValue.Descriptor))
            {
                return dataProperty.Value.Unpack<BoolValue>().Value.ToString();
            }

            return dataProperty.Value.ToString() ?? string.Empty;
        }
        catch
        {
            return string.Empty;
        }
    }


    private string GetStringValueByEntityPropertyGuid(string entityPropertyGuid)
    {
        try
        {
            if (DataObject == null ||
                DataObject.DataProperties == null ||
                string.IsNullOrWhiteSpace(entityPropertyGuid))
            {
                return string.Empty;
            }

            var parsedGuid = PWAFunctions.ParseAndReturnEmptyGuidIfInvalid(entityPropertyGuid).ToString();

            if (parsedGuid == Guid.Empty.ToString())
            {
                return string.Empty;
            }

            var property = DataObject.DataProperties.FirstOrDefault(p =>
                p.EntityPropertyGuid == parsedGuid);

            if (property?.Value is not Any packedValue)
            {
                return string.Empty;
            }

            if (packedValue.Is(StringValue.Descriptor))
            {
                return PWAFunctions.UnpackString(packedValue)?.Trim() ?? string.Empty;
            }

            if (packedValue.Is(Int32Value.Descriptor))
            {
                return PWAFunctions.UnpackInt32(packedValue).ToString();
            }

            if (packedValue.Is(Int64Value.Descriptor))
            {
                return PWAFunctions.UnpackInt64(packedValue).ToString();
            }

            if (packedValue.Is(DoubleValue.Descriptor))
            {
                return PWAFunctions.UnpackDouble(packedValue).ToString();
            }

            if (packedValue.Is(BoolValue.Descriptor))
            {
                return PWAFunctions.UnpackBool(packedValue) ? "Yes" : "No";
            }

            if (packedValue.Is(Timestamp.Descriptor))
            {
                return PWAFunctions.UnpackTimestamp(packedValue).ToString("dd/MM/yyyy");
            }

            return string.Empty;
        }
        catch
        {
            return string.Empty;
        }
    }

    private static string FirstNonEmpty(params string[] values)
    {
        return values.FirstOrDefault(x => !string.IsNullOrWhiteSpace(x)) ?? string.Empty;
    }

    private async Task OnCrumbClickAsync(int index)
    {
        if (index < 0 || index >= _breadcrumbs.Count)
            return;

        var crumb = _breadcrumbs[index];

        if (index < _breadcrumbs.Count - 1)
        {
            _breadcrumbs.RemoveRange(index + 1, _breadcrumbs.Count - index - 1);
        }

        _currentFolderId = crumb.FolderId;
        _currentFolderName = crumb.Name;
        _currentFolderWebUrl = string.Equals(_location?.RootFolderId, crumb.FolderId, StringComparison.OrdinalIgnoreCase)
            ? _location?.SharePointWebUrl
            : null;

        _currentLocationWarning = null;
        _selectedIds.Clear();

        await ExpandTreeToFolderAsync(crumb.FolderId);
        await LoadFolderAsync(crumb.FolderId, true);
    }

    private async Task OnSearchChangedAsync(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString() ?? string.Empty;
        await LoadFolderAsync(_currentFolderId, true);
    }

    private void PushBreadcrumb(string folderId, string folderName)
    {
        var existingIndex = _breadcrumbs.FindIndex(x =>
            string.Equals(x.FolderId, folderId, StringComparison.OrdinalIgnoreCase));

        if (existingIndex >= 0)
        {
            _breadcrumbs.RemoveRange(existingIndex + 1, _breadcrumbs.Count - existingIndex - 1);
            return;
        }

        _breadcrumbs.Add(new BreadcrumbItem
        {
            FolderId = folderId,
            Name = folderName
        });
    }

    private void ToggleSelected(string itemId, ChangeEventArgs e)
    {
        bool isChecked = e.Value switch
        {
            bool b => b,
            string s when bool.TryParse(s, out var parsed) => parsed,
            _ => false
        };

        if (isChecked)
            _selectedIds.Add(itemId);
        else
            _selectedIds.Remove(itemId);
    }

    private bool IsAllSelected()
    {
        if (_items.Count == 0)
            return false;

        return _items.All(x => _selectedIds.Contains(x.Id));
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        bool isChecked = e.Value switch
        {
            bool b => b,
            string s when bool.TryParse(s, out var parsed) => parsed,
            _ => false
        };

        _selectedIds.Clear();

        if (isChecked)
        {
            foreach (var item in _items)
            {
                _selectedIds.Add(item.Id);
            }
        }
    }

