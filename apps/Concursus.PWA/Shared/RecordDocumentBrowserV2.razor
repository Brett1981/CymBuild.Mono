    private async Task DeleteSelectedAsync()
    {
        if (FormHelper is null || _location is null)
            return;

        var selected = _items.Where(x => _selectedIds.Contains(x.Id)).ToList();
        if (selected.Count == 0)
            return;

        try
        {
            var confirmed = await JS.InvokeAsync<bool>("confirm", $"Delete {selected.Count} selected item(s)?");
            if (!confirmed)
                return;

            _busy = true;

            foreach (var item in selected)
            {
                await FormHelper.DocumentsDeleteAsync(
                    _location.SiteId,
                    _location.DriveId,
                    item.Id);
            }

            SetMessage($"{selected.Count} item(s) deleted.", false);
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            SetMessage(ex.Message, true);
        }
        finally
        {
            _busy = false;
        }
    }

