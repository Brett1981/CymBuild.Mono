        }
    }

    private void OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var value) && value > 0)
        {
            PageSize = value;
            CurrentPage = 1;
            StateHasChanged();
        }
    }

    private void PreviousPage()
    {
        if (CurrentPage > 1)
        {
            CurrentPage--;
        }
    }

    private void NextPage()
    {
        if (CurrentPage < TotalPages)
        {
            CurrentPage++;
        }
    }

    private void GoToPage(int pageNumber)
    {
        if (pageNumber >= 1 && pageNumber <= TotalPages)
        {
            CurrentPage = pageNumber;
        }
    }

    private void ResetToFirstPage() => CurrentPage = 1;

    private void EnsureValidPage()
    {
        if (CurrentPage > TotalPages)
        {
            CurrentPage = TotalPages;
        }

        if (CurrentPage < 1)
        {
            CurrentPage = 1;
        }
    }

    private void DebounceFilter()
    {
        filterDebounceTimer?.Dispose();
        filterDebounceTimer = new Timer(_ =>
        {
            _ = InvokeAsync(RebindChart);
        }, null, 200, Timeout.Infinite);
    }

    private string GetTimeGroupLabel(DateTime date)
    {
        return Grouping switch
        {
            TimeGrouping.Daily => date.ToString("dd MMM", GbpCulture),
            TimeGrouping.Weekly => $"Week {CultureInfo.CurrentCulture.Calendar.GetWeekOfYear(date, CalendarWeekRule.FirstDay, DayOfWeek.Monday)}",
            TimeGrouping.Monthly => date.ToString("MMM yyyy", GbpCulture),
            _ => date.ToString("dd MMM", GbpCulture)
        };
    }

    private static int GetMax(double quoteValue)
    {
        if (quoteValue <= 25000)
            return 25000;
        if (quoteValue <= 50000)
            return 50000;
        if (quoteValue <= 75000)
            return 75000;
        if (quoteValue <= 100000)
            return 100000;

        return int.MaxValue;
    }

    private static int GetMin(double quoteValue)
    {
        if (quoteValue <= 25000)
            return 0;
        if (quoteValue <= 50000)
            return 25001;
        if (quoteValue <= 75000)
            return 50001;
        if (quoteValue <= 100000)
            return 75001;

        return 100001;
    }

    private string GetValueRangeLabel(FilteredQuoteChartData row)
    {
        if (row.Max == int.MaxValue)
        {
            return "£100,001+";
        }

        var minLabel = row.Min <= 0 ? "£0" : row.Min.ToString("C0", GbpCulture);
        var maxLabel = row.Max.ToString("C0", GbpCulture);
        return $"{minLabel} - {maxLabel}";
    }

    private string BuildQuoteDetailUrl(string quoteGuid)
    {
        var dataObjectReference = new DataObjectReference(quoteGuid, "1c4794c1-f956-4c32-b886-5500ac778a56");
        var serializedReference = HttpUtility.UrlEncode(JsonConvert.SerializeObject(dataObjectReference));
        var returnUrl = HttpUtility.UrlEncode(NavManager.Uri);
        return $"{NavManager.BaseUri}QuoteDetail/{quoteGuid}/{serializedReference}/{returnUrl}";
    }

    private BreakdownItem CreateBreakdownItem(string label, int count, int total, string color)
    {
        var percentage = total > 0
            ? (int)Math.Round((decimal)count / total * 100m, MidpointRounding.AwayFromZero)
            : 0;

        return new BreakdownItem(label, count, percentage, color);
    }

    private string BuildColumnTooltip(TimelineGroup group)
    {
        var statusText = group.Segments.Count == 0
            ? "No data"
            : string.Join(", ", group.Segments.Select(x => $"{x.Status}: {x.Count}"));

        return $"{group.Label} - {group.Total} quote(s). {statusText}";
    }

    private static string NormaliseStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status))
        {
            return "Other";
        }

        return status.Trim();
    }

    private static bool IsStatus(string? status, string expected)
        => string.Equals(NormaliseStatus(status), expected, StringComparison.OrdinalIgnoreCase);

    private string GetStatusColor(string? status)
    {
        var normalisedStatus = NormaliseStatus(status);
        if (StatusColorMap.TryGetValue(normalisedStatus, out var knownColor))
        {
            return knownColor;
        }

        var index = Math.Abs(StringComparer.OrdinalIgnoreCase.GetHashCode(normalisedStatus)) % Palette.Length;
        var derivedColor = Palette[index];
        StatusColorMap[normalisedStatus] = derivedColor;
        return derivedColor;
    }

    private string GetOrgUnitGroupName(string? quoteType)
    {
        if (string.IsNullOrWhiteSpace(quoteType))
        {
            return "Other";
        }

        var trimmed = quoteType.Trim();
        var dashIndex = trimmed.IndexOf(" - ", StringComparison.Ordinal);
        if (dashIndex > 0)
        {
            return trimmed[..dashIndex].Trim();
        }

        var firstSpace = trimmed.IndexOf(' ');
        if (firstSpace > 0)
        {
            return trimmed[..firstSpace].Trim();
        }

        return trimmed;
    }

    private int GetThresholdComparisonValue() => ValueFilter >= BeyondThresholdValue ? 100000 : ValueFilter;
    private int GetSliderValue() => ValueFilter >= BeyondThresholdValue ? 100000 : ValueFilter;

    private string FormatCurrency(decimal value) => value.ToString("C0", GbpCulture);

    private string FormatThresholdLabel(int value)
        => value >= BeyondThresholdValue ? "Beyond £100K" : value.ToString("C0", GbpCulture);

    private async Task ExportToCsv()
    {
        var csv = new StringBuilder();
        csv.AppendLine("Date,Period,Status,QuoteType,Client,ValueRange,Count,EstimatedTotal,Quotes");

        foreach (var item in FilteredChartData.OrderByDescending(x => x.Date))
        {
            var quotes = string.Join(" | ", item.Quotes.OrderBy(q => q.QuoteNumber).Select(q => q.QuoteNumber));
            csv.AppendLine($"{item.Date:yyyy-MM-dd},{EscapeCsv(item.Label)},{EscapeCsv(item.Status)},{EscapeCsv(item.QuoteType)},{EscapeCsv(item.Client)},{EscapeCsv(GetValueRangeLabel(item))},{item.Value},{item.QuoteValue},{EscapeCsv(quotes)}");
        }

        var bytes = Encoding.UTF8.GetBytes(csv.ToString());
        var base64 = Convert.ToBase64String(bytes);
        await JsRuntime.InvokeVoidAsync("BlazorDownloadFile", "quote_dashboard_v2.csv", "text/csv", base64);
    }

    private async Task ExportToPdf()
    {
        await JsRuntime.InvokeVoidAsync(
            "exportToPdf",
            "quote-dashboard-export",
            $"quote_dashboard_{DateTime.Now:yyyyMMdd}.pdf");
    }

    private static string EscapeCsv(string? value)
    {
        var safe = value ?? string.Empty;
        if (safe.Contains(',') || safe.Contains('"') || safe.Contains('\n'))
        {
            safe = $"\"{safe.Replace("\"", "\"\"")}\"";
        }
        return safe;
    }

