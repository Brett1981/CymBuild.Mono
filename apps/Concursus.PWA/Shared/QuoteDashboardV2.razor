    {
        if (Enum.TryParse<TimeGrouping>(e.Value?.ToString(), out var result))
        {
            Grouping = result;
        }
    }

    private void OnStartDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var result))
        {
            StartDate = result;
            DebounceFilter();
        }
    }

    private void OnEndDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var result))
        {
            EndDate = result;
            DebounceFilter();
        }
