<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <staticContent>
      <remove fileExtension=".blat" />
      <remove fileExtension=".dat" />
      <remove fileExtension=".dll" />
      <remove fileExtension=".webcil" />
      <remove fileExtension=".json" />
      <remove fileExtension=".wasm" />
      <remove fileExtension=".woff" />
      <remove fileExtension=".woff2" />

      <mimeMap fileExtension=".blat" mimeType="application/octet-stream" />
      <mimeMap fileExtension=".dll" mimeType="application/octet-stream" />
      <mimeMap fileExtension=".webcil" mimeType="application/octet-stream" />
      <mimeMap fileExtension=".dat" mimeType="application/octet-stream" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <mimeMap fileExtension=".wasm" mimeType="application/wasm" />
      <mimeMap fileExtension=".woff" mimeType="application/font-woff" />
      <mimeMap fileExtension=".woff2" mimeType="application/font-woff2" />

      <!-- Long cache is still fine for immutable/fingerprinted assets.
           Critical bootstrap files are overridden below with no-store. -->
      <clientCache cacheControlMode="UseMaxAge"
                   cacheControlMaxAge="365.00:00:00" />
    </staticContent>

    <httpCompression>
      <dynamicTypes>
        <add mimeType="application/octet-stream" enabled="true" />
        <add mimeType="application/wasm" enabled="true" />
      </dynamicTypes>
    </httpCompression>

    <rewrite>
      <rules>
        <!-- Keep existing working rewrite logic -->
        <rule name="Serve subdir" stopProcessing="false">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{URL}" pattern="^/(QuoteDetail|EnquiryDetail|JobDetail|AssetDetail|AccountDetail|DynamicEdit)(/.*)?$" negate="true" />
          </conditions>
          <action type="Rewrite" url="wwwroot\{R:0}" />
        </rule>

        <rule name="SPA fallback routing" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{URL}" pattern="^/_framework/" negate="true" />
            <add input="{URL}" pattern="^/_content/" negate="true" />
            <add input="{URL}" pattern="\.(js|css|wasm|json|dll|webcil|dat|pdb|png|jpg|jpeg|gif|ico|woff|woff2)$" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="wwwroot\" />
        </rule>
      </rules>

      <outboundRules rewriteBeforeCache="true">

        <!-- HTML must never be stale -->
        <rule name="NoCache - Html responses" preCondition="IsHtmlResponse">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <action type="Rewrite" value="no-store, no-cache, must-revalidate, max-age=0" />
        </rule>
        <rule name="NoCache - Html responses (Pragma)" preCondition="IsHtmlResponse">
          <match serverVariable="RESPONSE_Pragma" pattern=".*" />
          <action type="Rewrite" value="no-cache" />
        </rule>
        <rule name="NoCache - Html responses (Expires)" preCondition="IsHtmlResponse">
          <match serverVariable="RESPONSE_Expires" pattern=".*" />
          <action type="Rewrite" value="0" />
        </rule>

        <!-- Service worker and manifest -->
        <rule name="NoCache - service-worker.js" preCondition="IsServiceWorkerJs">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <action type="Rewrite" value="no-store, no-cache, must-revalidate, max-age=0" />
        </rule>
        <rule name="NoCache - service-worker.js (Pragma)" preCondition="IsServiceWorkerJs">
          <match serverVariable="RESPONSE_Pragma" pattern=".*" />
          <action type="Rewrite" value="no-cache" />
        </rule>
        <rule name="NoCache - service-worker.js (Expires)" preCondition="IsServiceWorkerJs">
          <match serverVariable="RESPONSE_Expires" pattern=".*" />
          <action type="Rewrite" value="0" />
        </rule>

        <rule name="NoCache - service-worker-assets.js" preCondition="IsServiceWorkerAssetsJs">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <action type="Rewrite" value="no-store, no-cache, must-revalidate, max-age=0" />
        </rule>
        <rule name="NoCache - service-worker-assets.js (Pragma)" preCondition="IsServiceWorkerAssetsJs">
          <match serverVariable="RESPONSE_Pragma" pattern=".*" />
          <action type="Rewrite" value="no-cache" />
        </rule>
        <rule name="NoCache - service-worker-assets.js (Expires)" preCondition="IsServiceWorkerAssetsJs">
          <match serverVariable="RESPONSE_Expires" pattern=".*" />
          <action type="Rewrite" value="0" />
        </rule>

        <rule name="NoCache - manifest.json" preCondition="IsManifestJson">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <action type="Rewrite" value="no-store, no-cache, must-revalidate, max-age=0" />
        </rule>
        <rule name="NoCache - manifest.json (Pragma)" preCondition="IsManifestJson">
          <match serverVariable="RESPONSE_Pragma" pattern=".*" />
          <action type="Rewrite" value="no-cache" />
        </rule>
        <rule name="NoCache - manifest.json (Expires)" preCondition="IsManifestJson">
          <match serverVariable="RESPONSE_Expires" pattern=".*" />
          <action type="Rewrite" value="0" />
        </rule>

        <!-- App settings -->
        <rule name="NoCache - appsettings*.json" preCondition="IsAppSettingsJson">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <action type="Rewrite" value="no-store, no-cache, must-revalidate, max-age=0" />
        </rule>
        <rule name="NoCache - appsettings*.json (Pragma)" preCondition="IsAppSettingsJson">
          <match serverVariable="RESPONSE_Pragma" pattern=".*" />
          <action type="Rewrite" value="no-cache" />
        </rule>
        <rule name="NoCache - appsettings*.json (Expires)" preCondition="IsAppSettingsJson">
          <match serverVariable="RESPONSE_Expires" pattern=".*" />
          <action type="Rewrite" value="0" />
        </rule>

        <!-- Bootstrap/auth scripts that must never be stale -->
        <rule name="NoCache - sw-registrator.js" preCondition="IsSwRegistratorJs">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <action type="Rewrite" value="no-store, no-cache, must-revalidate, max-age=0" />
        </rule>
        <rule name="NoCache - service-worker-interop.js" preCondition="IsServiceWorkerInteropJs">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <action type="Rewrite" value="no-store, no-cache, must-revalidate, max-age=0" />
        </rule>
        <rule name="NoCache - blazor.webassembly.js" preCondition="IsBlazorWebAssemblyJs">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <action type="Rewrite" value="no-store, no-cache, must-revalidate, max-age=0" />
        </rule>
        <rule name="NoCache - blazor.boot.json" preCondition="IsBlazorBootJson">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <action type="Rewrite" value="no-store, no-cache, must-revalidate, max-age=0" />
        </rule>
        <rule name="NoCache - AuthenticationService.js" preCondition="IsAuthenticationServiceJs">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <action type="Rewrite" value="no-store, no-cache, must-revalidate, max-age=0" />
        </rule>

        <preConditions>
          <preCondition name="IsHtmlResponse">
            <add input="{RESPONSE_CONTENT_TYPE}" pattern="^text/html" />
          </preCondition>

          <preCondition name="IsServiceWorkerJs">
            <add input="{REQUEST_URI}" pattern="(^|.*/)service-worker\.js$" />
          </preCondition>

          <preCondition name="IsServiceWorkerAssetsJs">
            <add input="{REQUEST_URI}" pattern="(^|.*/)service-worker-assets\.js$" />
          </preCondition>

          <preCondition name="IsManifestJson">
            <add input="{REQUEST_URI}" pattern="(^|.*/)manifest\.json$" />
          </preCondition>

          <preCondition name="IsAppSettingsJson">
            <add input="{REQUEST_URI}" pattern="(^|.*/)appsettings(\..+)?\.json$" />
          </preCondition>

          <preCondition name="IsSwRegistratorJs">
            <add input="{REQUEST_URI}" pattern="(^|.*/)sw-registrator\.js$" />
          </preCondition>

          <preCondition name="IsServiceWorkerInteropJs">
            <add input="{REQUEST_URI}" pattern="(^|.*/)service-worker-interop\.js$" />
          </preCondition>

          <preCondition name="IsBlazorWebAssemblyJs">
            <add input="{REQUEST_URI}" pattern="(^|.*/)_framework/blazor\.webassembly\.js$" />
          </preCondition>

          <preCondition name="IsBlazorBootJson">
            <add input="{REQUEST_URI}" pattern="(^|.*/)_framework/blazor\.boot\.json$" />
          </preCondition>

          <preCondition name="IsAuthenticationServiceJs">
            <add input="{REQUEST_URI}" pattern="(^|.*/)_content/Microsoft\.Authentication\.WebAssembly\.Msal/AuthenticationService\.js$" />
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>

    <security>
      <requestFiltering allowDoubleEscaping="true" />
    </security>

  </system.webServer>
</configuration>