@inherits LayoutComponentBase
@using System.Reflection
@using Telerik.Blazor.Components
    <div class="main">
	<NavMenu />
	<TelerikRootComponent>
	<div class="content">
		<div class="container">
			@Body
		</div>
	</div>
	</TelerikRootComponent>
</div>

<footer class="d-flex align-items-center justify-content-center">
	<div class="row">
		Version: @version
	</div>
	<div class="row">
		@TrademarkMessage1
	</div>
	<div class="row">
		@TrademarkMessage2
	</div>
	<div class="row">
		Powered by: @System.Runtime.InteropServices.RuntimeInformation.FrameworkDescription
	</div>
</footer>


@code {
	public string TrademarkMessage1 { get; set; } = "Copyright © " + @DateTime.Now.Year + " Socotec.";
	public string TrademarkMessage2 { get; set; } = "All rights reserved.";
	public string version { get; set; } = "";

	protected override void OnInitialized()
	{
		var fullVersion = Assembly.GetExecutingAssembly().GetCustomAttribute<AssemblyInformationalVersionAttribute>()?.InformationalVersion ?? "";
		version = fullVersion.Split('+')[0]; // Split the version string and take the first part only.
	}
}