@using Telerik.Blazor.Components
@using Concursus.Components.Shared.Services
@using System.Linq.Expressions
@inject NavigationManager NavManager
@inject UserInteractionTrackerService InteractionTracker

@*
    TrackableTelerikTextBox.razor
    -------------------------------------------------------------------
    A wrapper for TelerikTextBox with user interaction tracking.

    Usage:
    <TrackableTelerikTextBox FieldName="My Field"
                              @bind-Value="model.Name"
                              Placeholder="Enter name"
                              ReadOnly="true"
                              class="form-control"
                              Id="textbox1" />
*@

<TelerikTextBox Value="Value"
                ValueChanged="@(EventCallback.Factory.Create<string?>(this, HandleValueChanged))"
                ValueExpression="ValueExpression"
                Id="@Id"
                Class="@Class"
                Placeholder="@Placeholder"
                ReadOnly="@ReadOnly"
                @attributes="AdditionalAttributes"
                OnBlur="@(() => LogInteraction(Value))" />

@code {
    [Parameter] public string FieldName { get; set; } = "UnknownTelerikField";

    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public Expression<Func<string?>>? ValueExpression { get; set; }

    [Parameter] public string? Id { get; set; }
    [Parameter] public string Class { get; set; } = "form-control";
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public bool ReadOnly { get; set; } = false;

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string PageKey => NavManager.Uri.Replace(NavManager.BaseUri, "").TrimEnd('/');

    private void LogInteraction(string? value)
    {
        string log = $"TelerikTextBox '{FieldName}' changed to '{value}'";
        InteractionTracker.Log(PageKey, log);
    }

    private async Task HandleValueChanged(string? newValue)
    {
        Value = newValue;

        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(newValue);
    }
}
