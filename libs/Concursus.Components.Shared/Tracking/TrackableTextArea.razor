@using Microsoft.AspNetCore.Components.Forms
@using System.Linq.Expressions
@using Concursus.Components.Shared.Services

@inject NavigationManager NavManager
@inject UserInteractionTrackerService InteractionTracker

<InputTextArea Value="Value"
               ValueChanged="@(EventCallback.Factory.Create<string?>(this, HandleValueChanged))"
               ValueExpression="ValueExpression"
               class="@Class"
               @onblur="TriggerOnBlur"
               @attributes="AdditionalAttributes" />

@code {
    [Parameter] public string FieldName { get; set; } = "UnknownTextArea";

    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public Expression<Func<string?>>? ValueExpression { get; set; }

    [Parameter] public string Class { get; set; } = "";
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string PageKey => NavManager.Uri.Replace(NavManager.BaseUri, "").TrimEnd('/');

    private void LogInteraction(string? value)
    {
        string log = $"TextArea '{FieldName}' changed to: '{value}'";
        InteractionTracker.Log(PageKey, log);
    }

    private async Task HandleValueChanged(string? newValue)
    {
        Value = newValue;
        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(newValue);
    }

    private async Task TriggerOnBlur()
    {
        LogInteraction(Value);
        // Could trigger other events here in future
        await Task.CompletedTask;
    }
}
