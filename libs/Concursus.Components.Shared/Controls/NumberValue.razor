<div class="gauge-container">
    <!-- Adjust the height as needed -->
    <TelerikCircularGauge>
        <CircularGaugeCenterLabel>
            <Template>
                @{
                    var pointer = Metric?.Values.FirstOrDefault();

                    <div style="font-weight: bold; font-size:40px">@pointer?.Value</div>
                }
            </Template>
        </CircularGaugeCenterLabel>
        <CircularGaugeScales>
            <!-- Currently hidding this scale as it is not needed -->
            @* <CircularGaugeScale Min="@Metric?.Min" Max="@Metric?.Max" MajorUnit="@Metric?.MajorUnit" MinorUnit="@Metric?.MinorUnit">
            <CircularGaugeScaleLabels Visible="true"/>
            </CircularGaugeScale> *@
        </CircularGaugeScales>
        <CircularGaugePointers>
            @*                     @if (Metric is not null)
            {
            @foreach (var v in Metric.Values)
            {
            <CircularGaugePointer Value="@v.Value" Color="@v.ColourHex">
            </CircularGaugePointer>
            }
            } *@
        </CircularGaugePointers>
    </TelerikCircularGauge>
</div>

<style>
    .gauge-container {
        position: relative;
        width: 100%;
        height: 100%; /* Adjust if necessary */
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden; /* Avoid scrollbars */
    }

    @@media (max-width: 1280px) {
    .k-gauge {
        transform: scale(0.6); /* Zoom out slightly */
    }

    @@media (max-width: 768px) {
        .gauge-container {
            transform: scale(1); /* Zoom out slightly */
        }

   

</style>