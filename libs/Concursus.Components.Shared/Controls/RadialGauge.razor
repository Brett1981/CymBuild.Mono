<div class="gauge-container">
    <!-- Adjust the height as needed -->
    <TelerikRadialGauge>
        <RadialGaugeScales>
            <RadialGaugeScale Min="@Metric.Min" Max="@Metric.Max" MajorUnit="@Metric.MajorUnit" MinorUnit="@Metric.MinorUnit" StartAngle="@Metric.StartAngle" EndAngle="@Metric.EndAngle">
                <RadialGaugeScaleRanges>
                    @foreach (var r in Metric.Ranges)
                    {
                        <RadialGaugeScaleRange From="r.MinValue" To="r.MaxValue" Color="@r.ColourHex"></RadialGaugeScaleRange>
                    }
                </RadialGaugeScaleRanges>
            </RadialGaugeScale>
        </RadialGaugeScales>
        <RadialGaugePointers>
            @foreach (var v in Metric.Values)
            {
                <RadialGaugePointer Value="@v.Value" Color="@v.ColourHex">
                </RadialGaugePointer>
            }
        </RadialGaugePointers>
    </TelerikRadialGauge>
</div>

<style>
    .gauge-container {
        position: relative;
        width: 100%;
        height: 100%; /* Adjust if necessary */
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden; /* Avoid scrollbars */
    }

    @@media (max-width: 1200px) {
        .gauge-container {
            transform: scale(0.6); /* Zoom out slightly */
        }

    @@media (max-width: 768px) {
        .gauge-container {
            transform: scale(1); /* Zoom out slightly */
        }
</style>