@inject IJSRuntime JS
@inject MemoryOverlayService OverlayService

@if (OverlayService.IsVisible)
{
    <div class="floating-diagnostics-panel panel-open">
        <div class="floating-panel-content">
            <h6 style="margin-top:0">Live Memory</h6>
            <ul>
                @foreach (var item in diagnostics)
                {
                    var isWarning = item.Metric == "GC Total Memory (bytes)" && TryParseBytes(item.Value) > 200_000_000
                    || item.Metric == "Telerik Grids Rendered" && TryParseInt(item.Value) > 5;

                    <li style="color:@(isWarning ? "#b80000" : "inherit"); font-weight:@(isWarning ? "600" : "normal")">
                        <b>@item.Metric:</b> @item.Value
                    </li>
                }
            </ul>
        </div>
    </div>
    <div class="floating-tab-handle" @onclick="OverlayService.Hide">
        Close Memory
    </div>
}
else
{
    <div class="floating-diagnostics-panel panel-closed"></div>
    <div class="floating-tab-handle" @onclick="OverlayService.Show">
        Open Memory
    </div>
}

@code {
    private List<MemoryMetric> diagnostics = new();
    private IJSObjectReference? _module;
    private System.Threading.Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        OverlayService.OnChanged += StateHasChanged;
        _module = await JS.InvokeAsync<IJSObjectReference>("import", "/memoryDiagnostics.js");
        await RefreshMetrics();
        _refreshTimer = new Timer(async _ => await RefreshMetrics(), null, 0, 5000);
    }

    private async Task RefreshMetrics()
    {
        if (_module == null)
        {
            return;
        }
        var gc = await _module.InvokeAsync<double>("getTotalMemory");
        var compCount = await _module.InvokeAsync<int>("getBlazorComponentCount");
        var jsCount = await _module.InvokeAsync<int>("getJSObjectReferenceCount");
        var cacheSize = await _module.InvokeAsync<double>("getServiceWorkerCacheSizeMB");
        var gridCount = await _module.InvokeAsync<int>("getTelerikGridCount");

        diagnostics = new()
        {
            new("GC Total Memory (bytes)", $"{gc:N0}"),
            new("Page Component Count", compCount.ToString()),
            new("Active JSObjectReferences", jsCount.ToString()),
            new("Service Worker Cache Size (MB)", $"{cacheSize:F2} MB"),
            new("Telerik Grids Rendered", gridCount.ToString()),
            new("Blazor Circuit Count", "N/A in WebAssembly")
        };

        await InvokeAsync(StateHasChanged);
    }

    private static int TryParseInt(string? value)
        => int.TryParse(value?.Split(' ')[0], out var i) ? i : 0;

    private static long TryParseBytes(string? value)
        => long.TryParse(value?.Split(' ')[0].Replace(",", ""), out var i) ? i : 0;

    public void Dispose()
    {
        OverlayService.OnChanged -= StateHasChanged;
        _refreshTimer?.Dispose();
    }

    public record MemoryMetric(string Metric, string Value);
}
